							decimal indOverallScoreKPIPerformance = 0, indOverallScoreKPIPerformanceQ1 = 0, indOverallScoreKPIPerformanceQ2 = 0, indOverallScoreKPIPerformanceQ3 = 0, indOverallScoreKPIPerformanceQ4 = 0;

