		private void sendEmail(SPWeb web, bool IsAttach, Stream contentStream, string fileName, string subject, string body)
		{
			// Check there is an email server configured
			if (SPUtility.IsEmailServerSet(web))
			{
				// Get the web app so we can get the email server SP is configured to use
				SPWebApplication webApp = web.Site.WebApplication;

				// Get the mail server details
				string smtpServerAddress = webApp.OutboundMailServiceInstance.Server.Address;
				int smtpServerPort = webApp.OutboundMailPort;
				string fromAddress = webApp.OutboundMailSenderAddress;
				string fromDomainAccount = webApp.OutboundMailUserName;
				SecureString fromAddressPassword = webApp.OutboundMailPassword;

				// Set up the mail server and sent the email
				using (SmtpClient client = new SmtpClient())
				{
					MailAddress from = new MailAddress(fromAddress);
					MailMessage message = new MailMessage
					{
						From = from
					};

					message.To.Add(web.CurrentUser.Email);
					message.Subject = subject;
					message.Body = body;
					message.IsBodyHtml = true;
					if (IsAttach)
					{
						// Your code to load the zip file as an SPFile              
						//Stream contentStream = spFile.OpenBinaryStream();
						var attachment = new Attachment(contentStream, fileName);
						message.Attachments.Add(attachment);
					}

					NEVER_EAT_POISON_Disable_CertificateValidation();
					client.DeliveryMethod = SmtpDeliveryMethod.Network;
					client.UseDefaultCredentials = false;
					client.Host = smtpServerAddress;
					client.Port = smtpServerPort;
					client.EnableSsl = false;
					string smtpUserName = fromDomainAccount;
					if (!string.IsNullOrEmpty(fromDomainAccount) && fromDomainAccount.Contains("\\"))
					{
						string[] parts = fromDomainAccount.Split('\\');
						if (parts.Length > 1)
						{
							smtpUserName = parts[1];
						}
					}

					client.Credentials = new NetworkCredential
					{
						UserName = smtpUserName,
						SecurePassword = fromAddressPassword
					};
					client.Send(message);
				}
			}
		}
		private void NEVER_EAT_POISON_Disable_CertificateValidation()
		{
			// Disabling certificate validation can expose you to a man-in-the-middle attack
			// which may allow your encrypted message to be read by an attacker
			// https://stackoverflow.com/a/14907718/740639
			ServicePointManager.ServerCertificateValidationCallback = delegate (object s, X509Certificate certificate, X509Chain chain, SslPolicyErrors sslPolicyErrors)
			{
				return true;
			};
		}
