		private decimal SafePercent(object numeratorObj, object denomObj)
		{
			decimal numerator = numeratorObj == null ? 0m : Convert.ToDecimal(numeratorObj);
			decimal denom = denomObj == null ? 0m : Convert.ToDecimal(denomObj);
			if (denom == 0m) return 0m;
			return Math.Round((numerator / denom) * 100m, 2);
		}
