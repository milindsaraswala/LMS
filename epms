private void RecalculateContractAndAddHistory(SPWeb web, SPListItem currentItem, string actionText, bool excludeCurrentItem)
{
	SPList listUserKPI = web.Lists.TryGetList("UserKPI");
	SPList listContract = web.Lists.TryGetList("Contract");
	SPList listCategories = web.Lists.TryGetList("Categories");
	SPList listContractHistory = web.Lists.TryGetList("ContractHistory");

	if (listUserKPI == null || listContract == null || listCategories == null || listContractHistory == null)
	{
		throw new Exception("One or more required lists were not found.");
	}

	SPFieldLookupValue lookupContract = new SPFieldLookupValue(Convert.ToString(currentItem["Contract"]));
	SPListItem itemContract = listContract.GetItemById(lookupContract.LookupId);
	if (itemContract == null)
	{
		throw new Exception("Related Contract item not found.");
	}

	SPFieldLookupValue lookupEmployee = new SPFieldLookupValue(Convert.ToString(itemContract["Employee"]));
	SPFieldLookupValue year = new SPFieldLookupValue(Convert.ToString(itemContract["Year"]));

	SPListItemCollection itemsUserKPI = getUserKPI(
		listUserKPI,
		lookupContract.LookupId,
		currentItem.ID,
		excludeCurrentItem
	);

	SPListItemCollection itemCollectionEnterPrise = getContractByEmployeeId(listContract, "800", Convert.ToString(year.LookupValue));

	SPListItemCollection itemContractDirectManager = new SPListItemCollection(listContract, new SPQuery());
	if (itemContract["Employee_x003a_DirectManagerId"] != null)
	{
		SPFieldLookupValue lookupEmployeeDirectManager = new SPFieldLookupValue(Convert.ToString(itemContract["Employee_x003a_DirectManagerId"]));
		if (!string.IsNullOrEmpty(lookupEmployeeDirectManager.LookupValue))
		{
			itemContractDirectManager = getContractByEmployeeId(listContract, lookupEmployeeDirectManager.LookupValue, Convert.ToString(year.LookupValue));
		}
	}

	decimal kpiPerformanceQ1 = 0, kpiPerformanceQ2 = 0, kpiPerformanceQ3 = 0, kpiPerformanceQ4 = 0;
	decimal kpiCappingQ1 = 0, kpiCappingQ2 = 0, kpiCappingQ3 = 0, kpiCappingQ4 = 0;
	decimal endNegativeResult = 0;

	decimal indOverallScoreKPIPerformanceWeightSingle = 0, indOverallScoreKPIPerformanceWeight = 0;

	int lowestStart = 4;

	foreach (SPListItem itemUserKPI in itemsUserKPI)
	{
		decimal indOverallScoreKPIPerformance = 0;
		decimal indOverallScoreKPIPerformanceQ1 = 0;
		decimal indOverallScoreKPIPerformanceQ2 = 0;
		decimal indOverallScoreKPIPerformanceQ3 = 0;
		decimal indOverallScoreKPIPerformanceQ4 = 0;

		SPFieldLookupValue category = new SPFieldLookupValue(Convert.ToString(itemUserKPI["Category"]));
		SPFieldLookupValue subcategory = new SPFieldLookupValue(Convert.ToString(itemUserKPI["SubCategory"]));
		SPFieldLookupValue kpiType = new SPFieldLookupValue(Convert.ToString(itemUserKPI["KPIType"]));

		SPListItemCollection itemsCategory = getCategory(
			listCategories,
			Convert.ToString(category.LookupValue),
			Convert.ToString(subcategory.LookupValue),
			Convert.ToString(year.LookupValue)
		);

		int start = ToInt(itemUserKPI["Start"]);
		int end = ToInt(itemUserKPI["End"]);
		int performanceCapping = 100;

		lowestStart = start < lowestStart ? start : lowestStart;

		decimal weight = ToDecimal(itemUserKPI["Weight"]);
		decimal perfQ1 = ToDecimal(itemUserKPI["PerformanceQ1"]);
		decimal perfQ2 = ToDecimal(itemUserKPI["PerformanceQ2"]);
		decimal perfQ3 = ToDecimal(itemUserKPI["PerformanceQ3"]);
		decimal perfQ4 = ToDecimal(itemUserKPI["PerformanceQ4"]);

		decimal actualQ1 = ToDecimal(itemUserKPI["ActualQ1"]);
		decimal actualQ2 = ToDecimal(itemUserKPI["ActualQ2"]);
		decimal actualQ3 = ToDecimal(itemUserKPI["ActualQ3"]);
		decimal actualQ4 = ToDecimal(itemUserKPI["ActualQ4"]);

		decimal kpiThreshold = ToDecimal(itemUserKPI["KPIThreshold"]);
		bool netProfit = ToBool(itemUserKPI["NetProfit"]);

		bool endResultOverwrite = false;
		if (itemsCategory != null && itemsCategory.Count > 0)
		{
			endResultOverwrite = ToBool(itemsCategory[0]["EndResultOverwrite"]);
		}

		if (endResultOverwrite == false)
		{
			if (start == 1 && perfQ1 != 0 && actualQ1 != 0)
			{
				kpiPerformanceQ1 += (perfQ1 * weight);
				kpiCappingQ1 += (performanceCapping * weight);
				indOverallScoreKPIPerformanceQ1 = perfQ1;
			}

			if (start <= 2 && end >= 2 && perfQ2 != 0 && actualQ2 != 0)
			{
				kpiPerformanceQ2 += (perfQ2 * weight);
				kpiCappingQ2 += (performanceCapping * weight);
				indOverallScoreKPIPerformanceQ2 = perfQ2;
			}

			if (start <= 3 && end >= 3 && perfQ3 != 0 && actualQ3 != 0)
			{
				kpiPerformanceQ3 += (perfQ3 * weight);
				kpiCappingQ3 += (performanceCapping * weight);
				indOverallScoreKPIPerformanceQ3 = perfQ3;
			}

			if (start <= 4 && end == 4 && perfQ4 != 0 && actualQ4 != 0)
			{
				kpiPerformanceQ4 += (perfQ4 * weight);
				kpiCappingQ4 += (performanceCapping * weight);
				indOverallScoreKPIPerformanceQ4 = perfQ4;
			}

			decimal chkOverallPerformance = ((indOverallScoreKPIPerformanceQ1 + indOverallScoreKPIPerformanceQ2 + indOverallScoreKPIPerformanceQ3 + indOverallScoreKPIPerformanceQ4) / (5 - start));

			indOverallScoreKPIPerformance = (kpiType.LookupValue == "Initiative" || netProfit == true)
				? indOverallScoreKPIPerformanceQ4
				: chkOverallPerformance;

			indOverallScoreKPIPerformance = indOverallScoreKPIPerformance < kpiThreshold ? 0 : indOverallScoreKPIPerformance;

			indOverallScoreKPIPerformanceWeightSingle = (weight * indOverallScoreKPIPerformance) / 100;
			indOverallScoreKPIPerformanceWeight += indOverallScoreKPIPerformanceWeightSingle;
		}
		else
		{
			if (ToBool(itemContract["EndNegativeFlag"]) == true)
			{
				endNegativeResult = ToDecimal(itemContract["EndNegativeResult"]);
			}
			else
			{
				endNegativeResult += perfQ4 == 0 ? weight : 0;
			}
		}
	}

	decimal performanceQ1 = SafePercent(kpiPerformanceQ1, kpiCappingQ1);
	decimal performanceQ2 = SafePercent(kpiPerformanceQ2, kpiCappingQ2);
	decimal performanceQ3 = SafePercent(kpiPerformanceQ3, kpiCappingQ3);
	decimal performanceQ4 = SafePercent(kpiPerformanceQ4, kpiCappingQ4);

	int periodQuater = (4 - lowestStart) + 1;
	if (periodQuater <= 0) periodQuater = 1;

	decimal endYearResult = Math.Round(((performanceQ1 + performanceQ2 + performanceQ3 + performanceQ4) / periodQuater) - (endNegativeResult * -1), 2);
	decimal indOverallScorePerformance = (indOverallScoreKPIPerformanceWeight - (endNegativeResult * -1));

	itemContract["PerformanceQ1"] = Math.Round(performanceQ1, 2);
	itemContract["PerformanceQ2"] = Math.Round(performanceQ2, 2);
	itemContract["PerformanceQ3"] = Math.Round(performanceQ3, 2);
	itemContract["PerformanceQ4"] = Math.Round(performanceQ4, 2);

	itemContract["EnterpriseScore"] = itemCollectionEnterPrise != null && itemCollectionEnterPrise.Count > 0
		? ToDecimal(itemCollectionEnterPrise[0]["EndYearResult"])
		: 0;

	itemContract["DirectManagerScore"] = itemContractDirectManager != null && itemContractDirectManager.Count > 0
		? ToDecimal(itemContractDirectManager[0]["EndYearResult"])
		: 0;

	itemContract["IndividualOverallScore"] = indOverallScorePerformance;

	itemContract["EnterpriseOverallScore"] = itemCollectionEnterPrise != null && itemCollectionEnterPrise.Count > 0
		? ToDecimal(itemCollectionEnterPrise[0]["IndividualOverallScore"])
		: 0;

	itemContract["DirectManagerOverallScore"] = itemContractDirectManager != null && itemContractDirectManager.Count > 0
		? ToDecimal(itemContractDirectManager[0]["IndividualOverallScore"])
		: 0;

	itemContract["EndNegativeResult"] = endNegativeResult;
	itemContract["EndYearResult"] = endYearResult;

	using (EventReceiverManager eventReceiverManager = new EventReceiverManager(true))
	{
		itemContract.Update();
	}

	SPListItem itemContractHistoryToAdd = listContractHistory.AddItem();

	itemContractHistoryToAdd["Contract"] = lookupContract;
	itemContractHistoryToAdd["Employee"] = lookupEmployee.LookupValue;
	itemContractHistoryToAdd["Year"] = itemContract["Year"];
	itemContractHistoryToAdd["Status"] = itemContract["Status"];
	itemContractHistoryToAdd["Stage"] = itemContract["Stage"];
	itemContractHistoryToAdd["Action"] = actionText;
	itemContractHistoryToAdd["ActionBy"] = web.CurrentUser != null ? web.CurrentUser.Name : string.Empty;
	itemContractHistoryToAdd["KPIDescription"] = currentItem["KPIDescription"];
	itemContractHistoryToAdd["PerformanceQ1"] = itemContract["PerformanceQ1"];
	itemContractHistoryToAdd["PerformanceQ2"] = itemContract["PerformanceQ2"];
	itemContractHistoryToAdd["PerformanceQ3"] = itemContract["PerformanceQ3"];
	itemContractHistoryToAdd["PerformanceQ4"] = itemContract["PerformanceQ4"];
	itemContractHistoryToAdd["EndNegativeResult"] = itemContract["EndNegativeResult"];
	itemContractHistoryToAdd["EndYearResult"] = itemContract["EndYearResult"];

	itemContractHistoryToAdd.Update();
}