private void ValidateRequiredColumns(DataTable dtExcel, string uploadType)
{
	List<string> requiredColumns = new List<string>();

	if (uploadType == "Initial")
	{
		requiredColumns.AddRange(new[]
		{
			"Year", "Category", "SubCategory", "KPIType", "Weight", "Baseline", "EndTarget",
			"TargetType", "DesiredTo", "Start", "End", "EmployeeID", "KPIDescription"
		});
	}
	else if (uploadType == "H1")
	{
		requiredColumns.AddRange(new[]
		{
			"Year", "EmployeeID", "KPIID", "ActualQ1", "ActualQ2"
		});
	}
	else if (uploadType == "H2")
	{
		requiredColumns.AddRange(new[]
		{
			"Year", "EmployeeID", "KPIID", "ActualQ3", "ActualQ4"
		});
	}

	foreach (string col in requiredColumns)
	{
		if (!dtExcel.Columns.Contains(col))
		{
			throw new Exception("Missing column in Excel sheet: " + col);
		}
	}
}