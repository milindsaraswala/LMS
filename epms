											msg += $"ActualQ4 cannot be updated as start or end of KPI period not Quater4.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
											continue;
										}
										else
										{
											actualQ4 = strActualQ4 == "" ? 0 : Convert.ToDouble(Convert.ToString(strActualQ4));
										}
