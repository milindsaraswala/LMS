		private IDictionary<string, double> targetCaluculation(string desiredTo, string targetType, double endTarget, double baseline, int start, int end)
		{
			var arr = new Dictionary<string, double>();
			int endMulti = 0;
			if (desiredTo == "Increase" && targetType == "Accumulative")
			{
				for (int i = 1; i <= 4; i++)
				{
					if (i < start)
					{
						arr[$"TargetQ{i}"] = 0;
					}
					else if (i > end || i == end || (i == start && i == end))
					{
						arr[$"TargetQ{i}"] = endTarget;
					}
					else
					{
						if (i == start)
						{
							endMulti = 1;
						}
						else
						{
							endMulti += 1;
						}

						arr[$"TargetQ{i}"] = Math.Round((baseline + (((endTarget - baseline) / ((end - start) + 1)) * endMulti)), 2);
					}
				}
			}
			else if (desiredTo == "Decrease" && targetType == "Accumulative")
			{
				for (int i = 1; i <= 4; i++)
				{
					if (baseline < endTarget || start > i)
					{
						arr[$"TargetQ{i}"] = 0;
					}
					else if (end <= i || start == end)
					{
						arr[$"TargetQ{i}"] = Math.Round((endTarget), 2);
					}
					else if (start == i)
					{
						arr[$"TargetQ{i}"] = Math.Round((baseline - ((baseline - endTarget) / ((end - start) + 1))), 2);
					}
					else if (start >= 2 && end == 4)
					{// i === 3
						arr[$"TargetQ{i}"] = Math.Round((baseline - ((baseline - endTarget) / ((end - start) + 1)) * (i - 1)), 2);
					}
					else
					{
						arr[$"TargetQ{i}"] = Math.Round((baseline - ((baseline - endTarget) / ((end - start) + 1)) * i), 2);
					}
				}
			}
			else if (desiredTo == "Increase" && targetType == "Maintenance")
			{
				for (int i = 1; i <= 4; i++)
				{
					if (i >= start)
					{
						arr[$"TargetQ{i}"] = Math.Round((endTarget), 2);
					}
					else
					{
						arr[$"TargetQ{i}"] = 0;
					}
				}
			}
			else if (desiredTo == "Decrease" && targetType == "Maintenance")
			{
				for (int i = 1; i <= 4; i++)
				{
					if (i >= start)
					{
						arr[$"TargetQ{i}"] = Math.Round((endTarget), 2);
					}
					else
					{
						arr[$"TargetQ{i}"] = 0;
					}
				}
			}
			return arr;

