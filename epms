				showBorders: true,
				showRowLines: true,
				rowAlternationEnabled: true,
				keyExpr: "Id",
				paging: {
					enabled: true,
					pageSize: 15
				},
				sorting: {
					mode: "multiple"
				},
				filterRow: {
					visible: true,
					applyFilter: "auto"
				},
				dataSource: dataUploadHistory,
				columns: ["Status", {
					dataField: "Created",
					caption: "Created Date",
					dataType: "datetime",
					customizeText(cellInfo) {
						return DevExpress.localization.formatDate(new Date(cellInfo.value), "MM/dd/yyyy HH:mm a");
					},
				}, {
						dataField: "Author.Title",
						caption: "Created By",
					}, {
						dataField: "TotalRecords",
					}, {
						dataField: "RowInserted",
						caption: "Inserted",
					}, {
						dataField: "RowFailed",
						caption: "Failed",
					}, {
						type: "buttons",
						name: "logs",
						caption: "Download Logs",
						width: 150,
						buttons: [{
							text: "Logs",
							visible(options) {
								return options.row.data.Status === "Failed";
							},
							onClick: async (el) => {
								// const _currentValue = processType.option("selectedItem");
								const dataCategories = await getSelectedYearCategories(selectedContractYear);
								const workbook = new ExcelJS.Workbook();
								const period = currentValue === "h1" ? "H1" : currentValue === "h2" ? "H2" : "Initial";
								let dataKPI;

								if (currentValue === "initial") {
									dataKPI = await getBulkLogData("BulkUploadLog", el.row.key);

									const worksheetKPI = workbook.addWorksheet("Initial Fialed Logs");
									const worksheetCategories = workbook.addWorksheet("Categories");

									worksheetKPI.columns = [
										{ letter: "A", header: "Year", key: "Title" },
										{ letter: "B", header: "EmployeeID", key: "EmployeeID" },
										{ letter: "C", header: "KPIDescription", key: "KPIDescription" },
										{ letter: "D", header: "Category", key: "Category" },
										{ letter: "E", header: "SubCategory", key: "SubCategory" },
										{ letter: "F", header: "KPIType", key: "KPIType" },
										{ letter: "G", header: "Weight", key: "Weight" },
										{ letter: "H", header: "Baseline", key: "Baseline" },
										{ letter: "I", header: "EndTarget", key: "EndTarget" },
										{ letter: "J", header: "TargetType", key: "TargetType" },
										{ letter: "K", header: "DesiredTo", key: "DesiredTo" },
										{ letter: "L", header: "Start", key: "Start" },
										{ letter: "M", header: "End", key: "End" },
										{ letter: "N", header: "WorkStep Objective", key: "WorkStepObjective" },
										{ letter: "O", header: "WorkStep Percentage", key: "WorkStepPercentage" },
										{ letter: "P", header: "WorkStep Start", key: "WorkStepStart" },
										{ letter: "Q", header: "WorkStep End", key: "WorkStepEnd" },
										{ letter: "R", header: "ErrMessage", key: "ErrMessage" },
									];
									worksheetKPI.addRows(dataKPI);

									worksheetCategories.columns = [
										{ letter: "A", header: "Category", key: "Category" },
										{ letter: "B", header: "SubCategory", key: "SubCategory" },
										{ letter: "C", header: "KPIType", key: "KPIType" },
										{ letter: "D", header: "Year", key: "Year" }
									];
									worksheetCategories.addRows(dataCategories);
								} else if (currentValue === "h1" || currentValue === "h2") {
									if (currentValue === "h1") {
										dataKPI = await getBulkLogData("BulkUploadH1Log", el.row.key);
									} else {
										dataKPI = await getBulkLogData("BulkUploadH2Log", el.row.key);
									}
									const worksheetKPI = workbook.addWorksheet(`${period} Fialed Logs`);
									const worksheetCategories = workbook.addWorksheet("Categories");

									worksheetKPI.columns = [
										{ letter: "A", header: "Year", key: "Title" },
										{ letter: "B", header: "EmployeeID", key: "EmployeeID" },
										{ letter: "C", header: "KPIID", key: "KPIID" },
										{ letter: "D", header: "KPIDescription", key: "KPIDescription" },
										{ letter: "E", header: "Category", key: "Category" },
										{ letter: "F", header: "SubCategory", key: "SubCategory" },
										{ letter: "G", header: "KPIType", key: "KPIType" },
										{ letter: "H", header: "Weight", key: "Weight" },
										{ letter: "I", header: "Baseline", key: "Baseline" },
										{ letter: "J", header: "EndTarget", key: "EndTarget" },
										{ letter: "K", header: "TargetType", key: "TargetType" },
										{ letter: "L", header: "DesiredTo", key: "DesiredTo" },
										{ letter: "M", header: "Start", key: "Start" },
										{ letter: "N", header: "End", key: "End" },
										...(currentValue === "h1" ? [{ letter: "O", header: "TargetQ1", key: "TargetQ1" }] : []),
										...(currentValue === "h1" ? [{ letter: "P", header: "ActualQ1", key: "ActualQ1" }] : []),
										...(currentValue === "h1" ? [{ letter: "Q", header: "TargetQ2", key: "TargetQ2" }] : []),
										...(currentValue === "h1" ? [{ letter: "R", header: "ActualQ2", key: "ActualQ2" }] : []),
										...(currentValue === "h2" ? [{ letter: "O", header: "TargetQ3", key: "TargetQ3" }] : []),
										...(currentValue === "h2" ? [{ letter: "P", header: "ActualQ3", key: "ActualQ3" }] : []),
										...(currentValue === "h2" ? [{ letter: "Q", header: "TargetQ4", key: "TargetQ4" }] : []),
										...(currentValue === "h2" ? [{ letter: "R", header: "ActualQ4", key: "ActualQ4" }] : []),
										{ letter: "S", header: "WorkStep Objective", key: "WorkStepObjective" },
										{ letter: "T", header: "WorkStep Percentage", key: "WorkStepPercentage" },
										{ letter: "U", header: "WorkStep Start", key: "WorkStepStart" },
										{ letter: "V", header: "WorkStep End", key: "WorkStepEnd" },
										...(currentValue === "h1" ? [{ letter: "X", header: "WorkStep TargetQ1", key: "WorkStepTargetQ1" }] : []),
										...(currentValue === "h1" ? [{ letter: "Y", header: "WorkStep ActualQ1", key: "WorkStepActualQ1" }] : []),
										...(currentValue === "h1" ? [{ letter: "Z", header: "WorkStep TargetQ2", key: "WorkStepTargetQ2" }] : []),
										...(currentValue === "h1" ? [{ letter: "AA", header: "WorkStep ActualQ2", key: "WorkStepActualQ2" }] : []),
										...(currentValue === "h2" ? [{ letter: "X", header: "WorkStep TargetQ3", key: "WorkStepTargetQ3" }] : []),
										...(currentValue === "h2" ? [{ letter: "Y", header: "WorkStep ActualQ3", key: "WorkStepActualQ3" }] : []),
										...(currentValue === "h2" ? [{ letter: "Z", header: "WorkStep TargetQ4", key: "WorkStepTargetQ4" }] : []),
										...(currentValue === "h2" ? [{ letter: "AA", header: "WorkStep ActualQ4", key: "WorkStepActualQ4" }] : []),
										{ letter: "W", header: "ErrMessage", key: "ErrMessage" },
									];
									worksheetKPI.addRows(dataKPI);

									worksheetCategories.columns = [
										{ letter: "A", header: "Category", key: "Category" },
										{ letter: "B", header: "SubCategory", key: "SubCategory" },
										{ letter: "C", header: "KPIType", key: "KPIType" },
										{ letter: "D", header: "Year", key: "Year" }
									];
									worksheetCategories.addRows(dataCategories);
								}
								const fileName = `BulkuploadLogs_${el.row.key}_${period}_${new Date().getTime()}`;

								workbook.xlsx.writeBuffer().then((buffer) => {
									saveAs(new Blob([buffer], { type: "application/octet-stream" }), `${fileName}.xlsx`);
								});
							},
						}]
					}, {
						type: "buttons",
						name: "attachments",
						caption: "Download Attachment",
						width: 150,
						buttons: [{
							text: "Attachment",
							onClick: async (el) => {
								const item: IItem = sp.web.lists.getByTitle("BulkUpload").items.getById(el.row.key);
								const attachments: IAttachmentInfo[] = await item.attachmentFiles();

								window.open(`${attachments[0].ServerRelativeUrl}`, "_blank");
							},
						}]
					}],
			});
		}

		$(".fileUpload .dx-button-mode-contained").addClass("dx-button-default");
	};
};
