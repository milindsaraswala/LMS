		private double calculatePerformance(string desiredTo, double baseline, double actual, double target, double performanceCapping)
		{
			double performance = 0;
			if (desiredTo == "Increase")
			{
				if (baseline >= actual)
				{
					performance = 0;
				}
				else
				{
					performance = Math.Round(((baseline - actual) / (baseline - target) * 100), 2);
				}
			}
			else if (desiredTo == "Decrease")
			{
				if (baseline <= actual)
				{
					performance = 0;
				}
				else
				{
					performance = Math.Round(((baseline - actual) / (baseline - target) * 100), 2);
				}
			}
			return performance > performanceCapping ? performanceCapping : performance;
		}
