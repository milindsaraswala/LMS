const createKPISheet = async (selectedContractYear: number) => {
	const year = await sp.web.lists.getByTitle("Year").items.select("Title").getById(selectedContractYear).get();

	const KPISheet = [{
		"Year": year ? year.Title : "",
		"EmployeeID": "",
		"KPIDescription": "",
		"Category": "",
		"SubCategory": "",
		"KPIType": "",
		"Weight": "",
		"Baseline": "",
		"EndTarget": "",
		"TargetType": "Accumulative, Maintenance",
		"DesiredTo": "Decrease, Increase",
		"Start": "1,2,3,4",
		"End": "1,2,3,4",
		"WorkStep Objective": "",
		"WorkStep Percentage": "",
		"WorkStep Start": "1,2,3,4",
		"WorkStep End": "1,2,3,4"
	}];

	return KPISheet;
};

const getSelectedYearCategories = async (selectedContractYear: number) => {
	const jsonCategories = [];
	const categories = await sp.web.lists
		.getByTitle("Categories")
		.items
		.filter(`YearId eq ${selectedContractYear} and isDeleted eq false`)
		.select("Title", "SubCategory", "Year/Title", "KPIType/Title")
		.expand("Year", "KPIType")
		.get();

	categories.forEach((item) => {
		jsonCategories.push({
			Category: item.Title,
			SubCategory: item.SubCategory,
			KPIType: item.KPIType.map(itm => itm.Title).join("; "),
			Year: item.Year.Title,
		});

	});

	return jsonCategories;
};

const getBulkLogData = async (listName: string, bulkUploadId: number) => {
	return await sp.web.lists
		.getByTitle(listName)
		.items
		.filter(`BulkUploadFileId eq ${bulkUploadId}`)
		.get();
};

