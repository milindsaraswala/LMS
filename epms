									kpiCappingQ4 += (Convert.ToDecimal(performanceCapping) * Convert.ToDecimal(itemUserKPI["Weight"]));

									// new field Phase III
									//if (pQ4 >= kpiThreshold)
									//{
									indOverallScoreKPIPerformanceQ4 = Convert.ToDecimal(itemUserKPI["PerformanceQ4"]);
									//}
									//else
									//{
									//	flagThreshold++;
									//}
								}
								//indOverallScoreKPIPerformance = ((indOverallScoreKPIPerformanceQ1 + indOverallScoreKPIPerformanceQ2 + indOverallScoreKPIPerformanceQ3 + indOverallScoreKPIPerformanceQ4) / (5 - start));
								//indOverallScoreKPIPerformanceWeightSingle = (Convert.ToDecimal(itemUserKPI["Weight"]) * indOverallScoreKPIPerformance) / 100;
								//indOverallScoreKPIPerformanceWeight += indOverallScoreKPIPerformanceWeightSingle;

