										SPList listWorkStep = properties.Web.Lists.TryGetList("WorkStep");
										double parseWorkStepActualQ3, workStepActualQ3 = 0, parseWorkStepActualQ4, workStepActualQ4 = 0;
										string strWorkStepActualQ3 = "", strWorkStepActualQ4 = "";
										SPListItemCollection itemWorkStep = null;

										if (isWorkStepString.LookupValue == "true")
										{
											flag = workstepObjective == "";
											if (flag == true)
											{
												j++;
												msg += $"WorkStep objective cannot be empty.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}

											itemWorkStep = checkWorkStep(listWorkStep, itemUserKPI[0].ID, workstepObjective);

											if (itemWorkStep.Count == 0)
											{
												flag = true;
												j++;
												msg += $"WorkStep objective is does not exists for current UserKPI {"KPI" + String.Format("{0:00000}", Convert.ToInt32(itemUserKPI[0].ID))}.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}

											flag = string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep ActualQ3"].ToString()) && string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep ActualQ4"].ToString());
											if (flag == true)
											{
												j++;
												msg += $"WorkStep ActualQ3 and ActualQ4 both cannot be empty, at least one of it should be filled.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}
											else if (!string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep ActualQ3"].ToString()) && !double.TryParse(Convert.ToString(dtExcel.Rows[i]["WorkStep ActualQ3"]), out parseWorkStepActualQ3))
											{
												j++;
												msg += $"WorkStep ActualQ3 not a number.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}
											else if (!string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep ActualQ4"].ToString()) && !double.TryParse(Convert.ToString(dtExcel.Rows[i]["WorkStep ActualQ4"]), out parseWorkStepActualQ4))
											{
												j++;
												msg += $"WorkStep ActualQ4 not a number.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}

											strWorkStepActualQ3 = !string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep ActualQ3"].ToString()) && double.TryParse(Convert.ToString(dtExcel.Rows[i]["WorkStep ActualQ3"]), out parseWorkStepActualQ3) ? dtExcel.Rows[i]["WorkStep ActualQ3"].ToString() : "";
											strWorkStepActualQ4 = !string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep ActualQ4"].ToString()) && double.TryParse(Convert.ToString(dtExcel.Rows[i]["WorkStep ActualQ4"]), out parseWorkStepActualQ4) ? dtExcel.Rows[i]["WorkStep ActualQ4"].ToString() : "";


											/*Not in period 3 and not null*/
											flag = (Convert.ToInt16(itemWorkStep[0]["Start"]) > 3 || Convert.ToInt16(itemWorkStep[0]["End"]) < 3) && strWorkStepActualQ3 != "";
											if (flag == true)
											{
												j++;
												msg += $"WorkStep ActualQ3 cannot be updated as start of KPI period not Quater3.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}
											else
											{
												workStepActualQ3 = strWorkStepActualQ3 == "" ? 0 : Convert.ToDouble(Convert.ToString(strWorkStepActualQ3));
											}
											/**/

											/*Not in period 4 and not null*/
											flag = (Convert.ToInt16(itemWorkStep[0]["End"]) != 4) && strWorkStepActualQ4 != "";
											if (flag == true)
											{
												j++;
												msg += $"WorkStep ActualQ4 cannot be updated as start or end of KPI period not Quater4.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}
											else
											{
												workStepActualQ4 = strWorkStepActualQ4 == "" ? 0 : Convert.ToDouble(Convert.ToString(strWorkStepActualQ4));
											}
											/**/
										}

										SPFieldLookupValue lookupKPIType = new SPFieldLookupValue(Convert.ToString(itemUserKPI[0]["KPIType"]));

										if (isWorkStepString.LookupValue == "true" && itemWorkStep != null && itemWorkStep.Count > 0)
										{
											flag = lookupKPIType.LookupValue == "Initiative" && workStepActualQ3 > workStepActualQ4;
											if (flag == true)
											{
												j++;
												msg += $"WorkStep ActualQ3 cannot be more than ActualQ4.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}

											flag = lookupKPIType.LookupValue == "Initiative" && Convert.ToDouble(itemWorkStep[0]["TargetQ3"]) < workStepActualQ3;
											if (flag == true)
											{
												j++;
												msg += $"WorkStep ActualQ3 cannot be more than TargetQ3.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}

											flag = lookupKPIType.LookupValue == "Initiative" && Convert.ToDouble(itemWorkStep[0]["TargetQ4"]) < workStepActualQ4;
											if (flag == true)
											{
												j++;
												msg += $"WorkStep ActualQ4 cannot be more than TargetQ4.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}

											flag = lookupKPIType.LookupValue == "Initiative" && (workStepActualQ3 < 0 || workStepActualQ4 < 0);
											if (flag == true)
											{
												j++;
												msg += $"WorkStep Actual cannot be less than zero.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, "H2");
												continue;
											}
										}

										if (flag == false)
										{
											string desiredTo = Convert.ToString(itemUserKPI[0]["DesiredTo"]);
											string targetType = Convert.ToString(itemUserKPI[0]["TargetType"]);
											double baseline = Convert.ToDouble(itemUserKPI[0]["Baseline"]);
											double targetQ3 = Convert.ToDouble(itemUserKPI[0]["TargetQ3"]);
											double targetQ4 = Convert.ToDouble(itemUserKPI[0]["TargetQ4"]);

											SPList listKPIType = properties.Web.Lists.TryGetList("Types");
											SPListItem itemKPIType = listKPIType.GetItemById(lookupKPIType.LookupId);
											double performanceCapping = Convert.ToDouble(itemKPIType["PerformanceCapping"]);

											SPListItem itemUserKPIUpdate = listUserKPI.Items.GetItemById(itemUserKPI[0].ID);

											if (strActualQ3 != "")
											{
												itemUserKPIUpdate["ActualQ3"] = actualQ3;
												itemUserKPIUpdate["PerformanceQ3"] = calculatePerformance(desiredTo, baseline, actualQ3, targetQ3, performanceCapping);
											}
											if (strActualQ4 != "")
											{
												itemUserKPIUpdate["ActualQ4"] = actualQ4;
												itemUserKPIUpdate["PerformanceQ4"] = calculatePerformance(desiredTo, baseline, actualQ4, targetQ4, performanceCapping);
											}
											itemUserKPIUpdate.Update();

											if (isWorkStepString.LookupValue == "true")
											{
												SPListItem itemWorkStepUpdate = listWorkStep.Items.GetItemById(itemWorkStep[0].ID);
												if (strWorkStepActualQ3 != "")
												{
													itemWorkStepUpdate["ActualQ3"] = workStepActualQ3;
												}
												if (strWorkStepActualQ4 != "")
												{
													itemWorkStepUpdate["ActualQ4"] = workStepActualQ4;
												}
												itemWorkStepUpdate.Update();
											}
										}
									}
								}

								if (j > 0) // Error
								{
									int totalRecords = dtExcel.Rows.Count;
									int recordsSuccess = dtExcel.Rows.Count - j;
									int recordsFail = j;

									updateStatus(currentItem, "Failed", totalRecords, recordsSuccess, recordsFail);

