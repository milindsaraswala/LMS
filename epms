using Microsoft.SharePoint;
using Microsoft.SharePoint.Administration;
using Microsoft.SharePoint.Utilities;
using System;
using System.Collections.Generic;
using System.Data;
using System.Data.OleDb;
using System.IO;
using System.Net;
using System.Net.Mail;
using System.Security;
using System.Linq;

namespace EPMSCloneYear.BulkUploadEventReceiver
{
	/// <summary>
	/// List Item Events
	/// </summary>
	public class BulkUploadEventReceiver : SPItemEventReceiver
	{
		public override void ItemAdded(SPItemEventProperties properties)
		{
			base.ItemAdded(properties);
		}

		public override void ItemUpdated(SPItemEventProperties properties)
		{
			base.ItemUpdated(properties);

			string afterStatus = Convert.ToString(properties.ListItem["Status"]);
			string beforeStatus = properties.BeforeProperties != null && properties.BeforeProperties["Status"] != null
				? Convert.ToString(properties.BeforeProperties["Status"])
				: string.Empty;

			// Process only when status changes TO Submitted
			if (!string.Equals(afterStatus, "Submitted", StringComparison.OrdinalIgnoreCase) ||
				string.Equals(beforeStatus, "Submitted", StringComparison.OrdinalIgnoreCase))
			{
				return;
			}

			string localFilePath = string.Empty;

			try
			{
				SPSecurity.RunWithElevatedPrivileges(delegate ()
				{
					using (SPSite site = new SPSite(properties.SiteId))
					using (SPWeb web = site.OpenWeb(properties.RelativeWebUrl))
					{
						web.AllowUnsafeUpdates = true;

						try
						{
							SPList list = web.Lists[properties.ListId];
							SPListItem currentItem = list.GetItemById(properties.ListItemId);

							string originalLogin = !string.IsNullOrEmpty(properties.UserLoginName)
								? properties.UserLoginName
								: web.CurrentUser.LoginName;

							SPUser originalUser = web.EnsureUser(originalLogin);
							string notifyEmail = originalUser != null ? originalUser.Email : web.CurrentUser.Email;
							string notifyName = originalUser != null ? originalUser.Name : web.CurrentUser.Name;

							SPFieldLookupValue lookupYear = currentItem["Year"] != null
								? new SPFieldLookupValue(Convert.ToString(currentItem["Year"]))
								: null;

							string selectedYear = lookupYear != null ? lookupYear.LookupValue : string.Empty;

							/*
							 * Initial:
							 * A1 (Year), B1 (Category), C1 (SubCategory), D1 (KPIType), E1 (Weight), F1 (Baseline),
							 * G1 (EndTarget), H1(TargetType), I1 (DesiredTo), J1 (Start), K1 (End),
							 * L1 (EmployeeID), M1 (KPIDescription), N1 (WorkStep Objective),
							 * O1 (WorkStep Percentage), P1 (WorkStep Champion), Q1 (WorkStep Start), R1 (WorkStep End)
							 */

							SPAttachmentCollection currentItemAttachments = currentItem.Attachments;
							if (currentItemAttachments == null || currentItemAttachments.Count == 0)
							{
								updateStatus(currentItem, "Failed", 0, 0, 0);
								sendEmail(web, notifyEmail, "Bulk upload failed", $"Dear {notifyName},<br/><br/>No attachment was found in the bulk upload item.");
								return;
							}

							string attachment = currentItemAttachments[0];
							string attachmentUrl = SPUrlUtility.CombineUrl(currentItem.Attachments.UrlPrefix, attachment);
							SPFile file = web.GetFile(attachmentUrl);

							if (file == null || !file.Exists)
							{
								updateStatus(currentItem, "Failed", 0, 0, 0);
								sendEmail(web, notifyEmail, "Bulk upload failed", $"Dear {notifyName},<br/><br/>Attached file could not be found.");
								return;
							}

							string filePath = file.Path.ToString();
							string[] fileNameSplit = filePath.Split('/');
							string fileName = fileNameSplit[fileNameSplit.Length - 1];
							int lastIndex = fileName.LastIndexOf('.');
							string fileExt = fileName.LastIndexOf('.') > -1 ? fileName.Substring(lastIndex + 1) : string.Empty;

							localFilePath = $@"E:\Temp\{DateTime.Now.Ticks}_{fileName}";

							using (FileStream fileStream = new FileStream(localFilePath, FileMode.Create, FileAccess.ReadWrite))
							{
								byte[] bArray = file.OpenBinary();
								fileStream.Write(bArray, 0, bArray.Length);
							}

							if (string.IsNullOrEmpty(fileExt))
							{
								updateStatus(currentItem, "Failed", 0, 0, 0);
								sendEmail(web, notifyEmail, "Bulk upload failed", $"Dear {notifyName},<br/><br/>Attached file extension is invalid.");
								return;
							}

							if (!fileExt.Equals("xls", StringComparison.OrdinalIgnoreCase) &&
								!fileExt.Equals("xlsx", StringComparison.OrdinalIgnoreCase))
							{
								updateStatus(currentItem, "Failed", 0, 0, 0);
								sendEmail(web, notifyEmail, "Bulk upload failed", $"Dear {notifyName},<br/><br/>Only Excel files (.xls / .xlsx) are allowed.");
								return;
							}

							string conn = string.Empty;
							if (fileExt.Equals("xls", StringComparison.OrdinalIgnoreCase))
							{
								conn = @"provider=Microsoft.Jet.OLEDB.4.0;Data Source=" + localFilePath + ";Extended Properties='Excel 8.0;HDR=Yes;IMEX=1';";
							}
							else
							{
								conn = @"Provider=Microsoft.ACE.OLEDB.12.0;Data Source=" + localFilePath + ";Extended Properties='Excel 12.0;HDR=YES;IMEX=1';";
							}

							SPList bulkUploadLog = null;
							string worksheetName = string.Empty;
							string uploadType = Convert.ToString(currentItem["UploadType"]);

							if (uploadType == "Initial")
							{
								bulkUploadLog = web.Lists.TryGetList("BulkUploadLog");
								worksheetName = "KPI";
							}
							else if (uploadType == "H1")
							{
								bulkUploadLog = web.Lists.TryGetList("BulkUploadH1Log");
								worksheetName = "H1";
							}
							else if (uploadType == "H2")
							{
								bulkUploadLog = web.Lists.TryGetList("BulkUploadH2Log");
								worksheetName = "H2";
							}
							else
							{
								updateStatus(currentItem, "Failed", 0, 0, 0);
								sendEmail(web, notifyEmail, "Bulk upload failed", $"Dear {notifyName},<br/><br/>UploadType is invalid.");
								return;
							}

							DataTable dtExcel = new DataTable();
							using (OleDbConnection con = new OleDbConnection(conn))
							{
								OleDbDataAdapter oleAdpt = new OleDbDataAdapter($"select * from [{worksheetName}$]", con);
								oleAdpt.Fill(dtExcel);
							}

							ValidateRequiredColumns(dtExcel, uploadType);

							int j = 0;
							HashSet<string> empIdKPIDescriptionHashSet = new HashSet<string>();
							HashSet<string> empIdKPIDescriptionWSObjectiveHashSet = new HashSet<string>();

							for (int i = 0; i < dtExcel.Rows.Count; i++)
							{
								string msg = string.Empty;
								bool flag = false;

								if (dtExcel.Columns.Contains("Errors") == false)
								{
									dtExcel.Columns.Add("Errors", typeof(string));
								}

								int parseYear;
								string year = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "Year")) &&
											  int.TryParse(GetCell(dtExcel.Rows[i], "Year"), out parseYear)
									? GetCell(dtExcel.Rows[i], "Year")
									: string.Empty;

								SPList listYear = web.Lists.TryGetList("Year");
								SPListItemCollection itemCollectionYear = checkYear(listYear, year);

								flag = year == "" || selectedYear != year || itemCollectionYear.Count == 0;
								if (flag)
								{
									j++;
									msg += $"Year should be {selectedYear} and should be numeric.\r\n";
									dtExcel.Rows[i]["Errors"] = msg;
									updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
									continue;
								}

								if (uploadType == "Initial")
								{
									int parseEmployee;
									string employee = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "EmployeeID")) &&
													  int.TryParse(GetCell(dtExcel.Rows[i], "EmployeeID"), out parseEmployee)
										? GetCell(dtExcel.Rows[i], "EmployeeID")
										: "";

									SPList listContract = web.Lists.TryGetList("Contract");
									SPListItemCollection itemCollectionContract = checkContract(listContract, year, employee);
									flag = employee == "" || itemCollectionContract.Count == 0;
									if (flag)
									{
										j++;
										msg += $"Employee is empty or employee contract stage is not planning and status not new or wrong employee id.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									string category = GetCell(dtExcel.Rows[i], "Category");
									string subCategory = GetCell(dtExcel.Rows[i], "SubCategory");
									string kpiType = GetCell(dtExcel.Rows[i], "KPIType");

									SPList listCategory = web.Lists.TryGetList("Categories");
									SPListItemCollection itemCollectionCategory = checkCategory(listCategory, year, category, subCategory, kpiType);

									flag = category == "" || subCategory == "" || kpiType == "" || itemCollectionCategory.Count == 0;
									if (flag)
									{
										j++;
										msg += $"Category or Subcategory or KPI type is wrong or they are not matching. \r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									double parseWeight;
									double weight = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "Weight")) &&
													double.TryParse(GetCell(dtExcel.Rows[i], "Weight"), out parseWeight)
										? Convert.ToDouble(GetCell(dtExcel.Rows[i], "Weight"))
										: 0;

									if (weight == 0)
									{
										j++;
										msg += $"Weight cannot be empty or zero and should be numbers only.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									bool endResultOverwrite = Convert.ToBoolean(itemCollectionCategory[0]["EndResultOverwrite"]);
									flag = (!endResultOverwrite && weight <= 0) || (endResultOverwrite && weight >= 0);
									if (flag)
									{
										j++;
										string dynamicMsg = !endResultOverwrite ? " or less than zero" : " or greater than zero";
										msg += $"Weight should be numeric and cannot be zero {dynamicMsg} for this {category}.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									string targetType = GetCell(dtExcel.Rows[i], "TargetType");
									flag = targetType != "Accumulative" && targetType != "Maintenance";
									if (flag)
									{
										j++;
										msg += $"Wrong target type.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									string desireTo = GetCell(dtExcel.Rows[i], "DesiredTo");
									flag = desireTo != "Decrease" && desireTo != "Increase";
									if (flag)
									{
										j++;
										msg += $"Wrong desired to.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									double parseBaseline, baseline = 0;
									string strBaseline = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "Baseline")) &&
														 double.TryParse(GetCell(dtExcel.Rows[i], "Baseline"), out parseBaseline)
										? GetCell(dtExcel.Rows[i], "Baseline")
										: "";
									if (strBaseline == "")
									{
										j++;
										msg += $"Baseline cannot be empty and should be numbers only.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}
									else
									{
										baseline = Convert.ToDouble(strBaseline);
									}

									double parseEndTarget, endTarget = 0;
									string strEndTarget = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "EndTarget")) &&
														  double.TryParse(GetCell(dtExcel.Rows[i], "EndTarget"), out parseEndTarget)
										? GetCell(dtExcel.Rows[i], "EndTarget")
										: "";
									if (strEndTarget == "")
									{
										j++;
										msg += $"End target cannot be empty and should be numbers only.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}
									else
									{
										endTarget = Convert.ToDouble(strEndTarget);
									}

									flag = (desireTo == "Increase" && endTarget <= baseline);
									if (flag)
									{
										j++;
										msg += $"When desire to value is increase than end target should be more than baseline.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									// Fixed logic
									flag = kpiType == "Initiative" &&
										   (endTarget != 100 || baseline != 0 || targetType != "Accumulative" || desireTo != "Increase");
									if (flag)
									{
										j++;
										msg += $"When KPtype value is Initiative than end target should be 100, baseline should be 0, target type should be Accumulative and desireTo should be Increase.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									flag = (desireTo == "Decrease" && endTarget >= baseline);
									if (flag)
									{
										j++;
										msg += $"When desire to value is decrease than end target should be less than baseline.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									int parseStart;
									int start = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "Start")) &&
												int.TryParse(GetCell(dtExcel.Rows[i], "Start"), out parseStart)
										? Convert.ToInt16(GetCell(dtExcel.Rows[i], "Start"))
										: 0;
									if (start == 0)
									{
										j++;
										msg += $"Start cannot be empty or zero and should be numbers only.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									int parseEnd;
									int end = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "End")) &&
											  int.TryParse(GetCell(dtExcel.Rows[i], "End"), out parseEnd)
										? Convert.ToInt16(GetCell(dtExcel.Rows[i], "End"))
										: 0;
									if (end == 0)
									{
										j++;
										msg += $"End cannot be empty and should be numbers only.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									flag = endResultOverwrite && (start != 4 || end != 4);
									if (flag)
									{
										j++;
										msg += $"{category} start and end should be Q4 only.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									flag = start == 0 || start > end;
									if (flag)
									{
										j++;
										msg += $"Start cannot be zero or start cannot be greater end.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									string kpiDescription = GetCell(dtExcel.Rows[i], "KPIDescription");
									string keyKPI = $"{employee}:{NormalizeKey(kpiDescription)}";

									SPList listkpiTypes = web.Lists.TryGetList("Types");
									SPListItemCollection itemCollectionkpiTypes = checkKPIType(listkpiTypes, kpiType, year);

									if (kpiDescription == "")
									{
										j++;
										msg += $"KPI description cannot be empty.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									if (itemCollectionkpiTypes.Count == 0)
									{
										j++;
										msg += $"KPI Type is invalid.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									bool isWorkStepType = Convert.ToBoolean(itemCollectionkpiTypes[0]["IsWorkStep"]);

									if (empIdKPIDescriptionHashSet.Contains(keyKPI) && isWorkStepType == false)
									{
										j++;
										msg += $"KPI description is duplicate in the excel file.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}
									else
									{
										empIdKPIDescriptionHashSet.Add(keyKPI);
									}

									SPList listUserKPI = web.Lists.TryGetList("UserKPI");
									SPListItemCollection itemUserKPI = checkUserKPI(listUserKPI, Convert.ToInt32(itemCollectionContract[0].ID), kpiDescription);
									string workstepObjective = GetCell(dtExcel.Rows[i], "WorkStep Objective");

									if (itemUserKPI.Count > 0 && isWorkStepType == false)
									{
										j++;
										msg += $"KPI description is already in use for current year contract.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}
									else if (itemUserKPI.Count > 0 && isWorkStepType == true)
									{
										SPList workStep = web.Lists.TryGetList("WorkStep");
										SPListItemCollection itemWorkStep = checkWorkStep(workStep, itemUserKPI[0].ID, workstepObjective);

										if (itemWorkStep.Count > 0)
										{
											j++;
											msg += $"WorkStep description is already in exists for current UserKPI {"KPI" + String.Format("{0:00000}", Convert.ToInt32(itemUserKPI[0].ID))}.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;
											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
											continue;
										}
									}

									int parseWorkstepStart, workstepStart = 0, parseWorkstepEnd, workstepEnd = 0;
									double parseWorkstepPercentage, workstepPercentage = 0;

									if (workstepObjective != "" && isWorkStepType)
									{
										string keyKPIWS = $"{employee}:{NormalizeKey(kpiDescription)}:{NormalizeKey(workstepObjective)}";

										if (empIdKPIDescriptionWSObjectiveHashSet.Contains(keyKPIWS))
										{
											j++;
											msg += $"KPI description and Workstep object is duplicate in the excel file.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;
											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
											continue;
										}
										else
										{
											empIdKPIDescriptionWSObjectiveHashSet.Add(keyKPIWS);
										}

										workstepPercentage = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "WorkStep Percentage")) &&
															 double.TryParse(GetCell(dtExcel.Rows[i], "WorkStep Percentage"), out parseWorkstepPercentage)
											? Convert.ToDouble(GetCell(dtExcel.Rows[i], "WorkStep Percentage"))
											: 0;
										flag = workstepPercentage == 0 || workstepPercentage > 100;
										if (flag)
										{
											j++;
											msg += $"Percentage cannot be empty or zero or cannot be more than 100%.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;
											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
											continue;
										}

										workstepStart = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "WorkStep Start")) &&
														int.TryParse(GetCell(dtExcel.Rows[i], "WorkStep Start"), out parseWorkstepStart)
											? Convert.ToInt16(GetCell(dtExcel.Rows[i], "WorkStep Start"))
											: 0;
										if (workstepStart == 0)
										{
											j++;
											msg += $"Workstep start cannot be empty or zero and should be numbers only.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;
											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
											continue;
										}

										workstepEnd = !string.IsNullOrEmpty(GetCell(dtExcel.Rows[i], "WorkStep End")) &&
													  int.TryParse(GetCell(dtExcel.Rows[i], "WorkStep End"), out parseWorkstepEnd)
											? Convert.ToInt16(GetCell(dtExcel.Rows[i], "WorkStep End"))
											: 0;
										if (workstepEnd == 0)
										{
											j++;
											msg += $"Workstep end cannot be empty or zero and should be numbers only.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;
											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
											continue;
										}

										flag = (workstepStart < start) || (workstepEnd > end) || (workstepStart > workstepEnd);
										if (flag)
										{
											j++;
											msg += $"Worksteps start and end should between or equal to UserKPI start and end.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;
											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
											continue;
										}
									}
									else if (workstepObjective == "" && isWorkStepType)
									{
										j++;
										msg += $"This category needs worksteps.";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}
									else if (workstepObjective != "" && isWorkStepType == false)
									{
										j++;
										msg += $"Workstep objective is empty or {kpiType} cannot create worksteps.";
										dtExcel.Rows[i]["Errors"] = msg;
										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID, uploadType);
										continue;
									}

									if (flag == false)
									{
										SPFieldLookupValue lookupContract = new SPFieldLookupValue(itemCollectionContract[0].ID, itemCollectionContract[0].Title);
										SPFieldLookupValue lookupCategory = new SPFieldLookupValue(itemCollectionCategory[0].ID, itemCollectionCategory[0].Title);
										SPFieldLookupValue lookupSubCategory = new SPFieldLookupValue(itemCollectionCategory[0].ID, Convert.ToString(itemCollectionCategory[0]["SubCategory"]));
										SPFieldLookupValue lookupKPIType = new SPFieldLookupValue(itemCollectionkpiTypes[0].ID, itemCollectionkpiTypes[0].Title);
										IDictionary<string, double> target = targetCaluculation(desireTo, targetType, endTarget, baseline, Convert.ToInt16(start), Convert.ToInt16(end));

										SPFieldLookupValue lookupUserKPIWorkStep;

										if (itemUserKPI.Count == 0)
										{
											SPListItem itemUserKPIToAdd = listUserKPI.AddItem();
											SPFieldLookupValue lookupEmployee = new SPFieldLookupValue(Convert.ToString(itemCollectionContract[0]["Employee"]));

											itemUserKPIToAdd["Contract"] = lookupContract;
											itemUserKPIToAdd["Category"] = lookupCategory;
											itemUserKPIToAdd["SubCategory"] = lookupSubCategory;
											itemUserKPIToAdd["KPIType"] = lookupKPIType;
											itemUserKPIToAdd["KPIDescription"] = kpiDescription;
											itemUserKPIToAdd["Weight"] = weight;
											itemUserKPIToAdd["Baseline"] = baseline;
											itemUserKPIToAdd["EndTarget"] = endTarget;
											itemUserKPIToAdd["TargetType"] = targetType;
											itemUserKPIToAdd["DesiredTo"] = desireTo;
											itemUserKPIToAdd["Start"] = start;
											itemUserKPIToAdd["End"] = end;
											itemUserKPIToAdd["isDeleted"] = false;
											itemUserKPIToAdd["TargetQ1"] = target["TargetQ1"];
											itemUserKPIToAdd["ActualQ1"] = null;
