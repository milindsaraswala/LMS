				// loadPanel.hide();
			}
		} else {
			let dataUploadHistory = [];
			const userId = context.pageContext.legacyPageContext.userId;
			const filterCreatedBy = isMember ? "" : `Author/Id eq ${userId} and `;
			if (currentValue === "initial") {
				dataUploadHistory = await sp.web.lists
					.getByTitle("BulkUpload")
					.items
					.select("Id", "YearId", "Status", "Created", "Author/Title", "TotalRecords", "RowInserted", "RowFailed")
					.expand("Author")
					.filter(`${filterCreatedBy}YearId eq ${selectedContractYear} and UploadType eq 'Initial'`)
					.get();
			} else if (currentValue === "h1") {
				dataUploadHistory = await sp.web.lists
					.getByTitle("BulkUpload")
					.items
					.select("Id", "YearId", "Status", "Created", "Author/Title", "TotalRecords", "RowInserted", "RowFailed")
					.expand("Author")
					.filter(`${filterCreatedBy}YearId eq ${selectedContractYear} and UploadType eq 'H1'`)
					.get();
			} else if (currentValue === "h2") {
				dataUploadHistory = await sp.web.lists
					.getByTitle("BulkUpload")
					.items
					.select("Id", "YearId", "Status", "Created", "Author/Title", "TotalRecords", "RowInserted", "RowFailed")
					.expand("Author")
					.filter(`${filterCreatedBy}YearId eq ${selectedContractYear} and UploadType eq 'H2'`)
					.get();
