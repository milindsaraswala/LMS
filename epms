								decimal chkOverallPerformance = ((indOverallScoreKPIPerformanceQ1 + indOverallScoreKPIPerformanceQ2 + indOverallScoreKPIPerformanceQ3 + indOverallScoreKPIPerformanceQ4) / (5 - start));
								indOverallScoreKPIPerformance = (kpiType.LookupValue == "Initiative" || netProfit == true) ? indOverallScoreKPIPerformanceQ4 : chkOverallPerformance;
