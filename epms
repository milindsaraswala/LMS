									sendEmail(web, false, null, "", "Error inserting KPI", emailBody);
								}
								else
								{
									string emailBody = $"Dear {web.CurrentUser.Name},<br/><br/>Your data is added successfully.";
									int totalRecords = dtExcel.Rows.Count;
									int recordsSuccess = dtExcel.Rows.Count - j;
									int recordsFail = j;

									updateStatus(currentItem, "Success", totalRecords, recordsSuccess, recordsFail);

									//Comment Temporary			
									sendEmail(web, false, null, "", "All KPI data added successfully.", emailBody);
								}
							}
						}
