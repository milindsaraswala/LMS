
using Microsoft.SharePoint;
using Microsoft.SharePoint.Administration;
using Microsoft.SharePoint.Utilities;
using System;
using System.Collections.Generic;
using System.Data;
using System.Data.OleDb;
using System.IO;
using System.Linq;
using System.Net;
using System.Net.Mail;
using System.Net.Security;
using System.Security;
using System.Security.Cryptography.X509Certificates;

namespace EPMSCloneYear.BulkUploadEventReceiver
{
	/// <summary>
	/// List Item Events
	/// </summary>
	public class BulkUploadEventReceiver : SPItemEventReceiver
	{
		/// <summary>
		/// An item was added.
		/// </summary>
		public override void ItemAdded(SPItemEventProperties properties)
		{
			base.ItemAdded(properties);
		}

		/// <summary>
		/// An item was updated.
		/// </summary>
		public override void ItemUpdated(SPItemEventProperties properties)
		{
			base.ItemUpdated(properties);

			string afterStatus = Convert.ToString(properties.ListItem["Status"]);
			string beforeStatus = properties.BeforeProperties != null && properties.BeforeProperties["Status"] != null ?
				Convert.ToString(properties.BeforeProperties["Status"])
				: String.Empty;

			if (!string.Equals(afterStatus, "Submitted", StringComparison.OrdinalIgnoreCase) ||
				string.Equals(beforeStatus, "Submitted", StringComparison.OrdinalIgnoreCase))
			{
				return;
			}

			string localFilePath = string.Empty;

			try
			{
				SPSecurity.RunWithElevatedPrivileges(delegate ()
				{
					using (SPSite site = new SPSite(properties.SiteId))
					using (SPWeb web = site.OpenWeb(properties.RelativeWebUrl))
					{
						web.AllowUnsafeUpdates = true;

						try
						{
							SPList list = web.Lists[properties.ListId];
							SPListItem currentItem = list.GetItemById(properties.ListItemId);

							SPFieldLookupValue lookupYear = new SPFieldLookupValue(Convert.ToString(currentItem["Year"]));

							/*
							* A1 (Year), B1 (Category), C1 (SubCategory), D1 (KPIType), E1 (Weight), F1 (Baseline), G1 (EndTarget), H1(TargetType)
							* I1 (DesireTo), J1 (Start), K1 (End), L1 (EmployeeId), M1 (KPIDescription)
							* N1 (WorkStep Objective), O1 (WorkStep Percentage), P1 (WorkStep Champion), Q1 (WorkStep Start), R1 (WorkStep End)
							*/

							SPAttachmentCollection currentItemAttachments = currentItem.Attachments;
							if (currentItemAttachments == null || currentItemAttachments.Count == 0)
							{
								updateStatus(currentItem, "Failed", 0, 0, 0);
								return;
							}

							string attachment = currentItemAttachments[0];
							string t = SPUrlUtility.CombineUrl(currentItem.Attachments.UrlPrefix, attachment);
							SPFile file = properties.Web.GetFile(t);

							string filePath = file.Path.ToString(); //get the path of the file
							string[] fileNameSplit = filePath.Split('/');
							string _fileName = fileNameSplit[fileNameSplit.Length - 1];
							int lastIndex = _fileName.LastIndexOf('.');
							string fileExt = _fileName.LastIndexOf('.') > -1 ? _fileName.Substring(lastIndex + 1) : "";

							localFilePath = $"E:\\Temp\\{DateTime.Now.Ticks}_{_fileName}";

							using (FileStream fileStream = new FileStream(localFilePath, FileMode.Create, FileAccess.ReadWrite))
							{
								byte[] bArray = file.OpenBinary();
								fileStream.Write(bArray, 0, bArray.Length);
							}

							if (String.IsNullOrEmpty(fileExt))
							{
								return;
							}
							else if (fileExt.CompareTo("xls") == 0 || fileExt.CompareTo("xlsx") == 0)
							{
								string conn = "";
								if (fileExt.CompareTo("xls") == 0)
								{
									conn = @"provider=Microsoft.Jet.OLEDB.4.0;Data Source=" + localFilePath + ";Extended Properties='Excel 8.0;HRD=Yes;IMEX=1';"; //for below excel 2007
								}
								else
								{
									conn = @"Provider=Microsoft.ACE.OLEDB.12.0;Data Source=" + localFilePath + ";Extended Properties='Excel 12.0;HDR=YES';"; //for above excel 2007
								}

								SPList bulkUploadLog = null;
								String worksheetName = "";
								if (Convert.ToString(currentItem["UploadType"]) == "Initial")
								{
									bulkUploadLog = properties.Web.Lists.TryGetList("BulkUploadLog");
									worksheetName = "KPI";
								}
								else if (Convert.ToString(currentItem["UploadType"]) == "H1")
								{
									bulkUploadLog = properties.Web.Lists.TryGetList("BulkUploadH1Log");
									worksheetName = "H1";
								}
								else if (Convert.ToString(currentItem["UploadType"]) == "H2")
								{
									bulkUploadLog = properties.Web.Lists.TryGetList("BulkUploadH2Log");
									worksheetName = "H2";
								}

								DataTable dtExcel = new DataTable();
								using (OleDbConnection con = new OleDbConnection(conn))
								{
									OleDbDataAdapter oleAdpt = new OleDbDataAdapter($"select * from [{worksheetName}$]", con); //here we read data from sheet1
									oleAdpt.Fill(dtExcel); //fill excel data into dataTable
								}

								ValidateRequiredColumns(dtExcel, Convert.ToString(currentItem["UploadType"]));

								int j = 0;
								HashSet<string> empIdKPIDescriptionHashSet = new HashSet<string>();
								HashSet<string> empIdKPIDescriptionWSObjectiveHashSet = new HashSet<string>();

								for (int i = 0; i < dtExcel.Rows.Count; i++)
								{
									string msg = "";
									bool flag = false;
									string currentYear = lookupYear != null ? lookupYear.LookupValue : "";  // DateTime.Now.Year.ToString();

									if (dtExcel.Columns.Contains("Errors") == false)
									{
										dtExcel.Columns.Add("Errors", typeof(string));
									}

									int parseYear;
									string year = !string.IsNullOrEmpty(dtExcel.Rows[i]["Year"].ToString()) && int.TryParse(dtExcel.Rows[i]["Year"].ToString(), out parseYear) ? Convert.ToString(dtExcel.Rows[i]["Year"].ToString()) : "";
									SPList listYear = properties.Web.Lists.TryGetList("Year");
									SPListItemCollection itemCollectionYear = checkYear(listYear, year);
									flag = year == "" || currentYear != year || itemCollectionYear.Count == 0;

									if (flag == true)
									{
										j++;
										msg += $"Year should be {currentYear} and should be numeric.\r\n";
										dtExcel.Rows[i]["Errors"] = msg;

										updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
										continue;
									}

									if (Convert.ToString(currentItem["UploadType"]) == "Initial")
									{
										int parseEmployee;
										string employee = !string.IsNullOrEmpty(dtExcel.Rows[i]["EmployeeID"].ToString()) && int.TryParse(dtExcel.Rows[i]["EmployeeID"].ToString(), out parseEmployee) ? dtExcel.Rows[i]["EmployeeID"].ToString() : "";
										SPList listContract = properties.Web.Lists.TryGetList("Contract");
										SPListItemCollection itemCollectionContract = checkContract(listContract, year, employee);
										flag = employee == "" || itemCollectionContract.Count == 0;
										if (flag == true)
										{
											j++;
											msg += $"Employee is empty or employee contract stage is not planning and status not new or wrong employee id.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										string category = string.IsNullOrEmpty(dtExcel.Rows[i]["Category"].ToString()) ? "" : dtExcel.Rows[i]["Category"].ToString();
										string subCategory = string.IsNullOrEmpty(dtExcel.Rows[i]["SubCategory"].ToString()) ? "" : dtExcel.Rows[i]["SubCategory"].ToString();
										string kpiType = string.IsNullOrEmpty(dtExcel.Rows[i]["KPIType"].ToString()) ? "" : dtExcel.Rows[i]["KPIType"].ToString();
										SPList listCategory = properties.Web.Lists.TryGetList("Categories");
										SPListItemCollection itemCollectionCategory = checkCategory(listCategory, year, category, subCategory, kpiType);
										flag = category == "" || subCategory == "" || kpiType == "" || itemCollectionCategory.Count == 0;
										if (flag == true)
										{
											j++;
											msg += $"Category or Subcategory or KPI type is wrong or they are not matching. \r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										double parseWeight;
										double weight = !string.IsNullOrEmpty(dtExcel.Rows[i]["Weight"].ToString()) && double.TryParse(dtExcel.Rows[i]["Weight"].ToString(), out parseWeight) ? Convert.ToDouble(dtExcel.Rows[i]["Weight"].ToString()) : 0;
										if (weight == 0)
										{
											j++;
											msg += $"Weight cannot be empty or zero and should be numbers only.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										flag = (Convert.ToBoolean(itemCollectionCategory[0]["EndResultOverwrite"]) == false && weight <= 0) || (Convert.ToBoolean(itemCollectionCategory[0]["EndResultOverwrite"]) == true && weight >= 0);
										if (flag == true)
										{
											j++;
											string dynamicMsg = Convert.ToBoolean(itemCollectionCategory[0]["EndResultOverwrite"]) == false ? " or less than zero" : " or greater than zero";
											msg += $"Weight should be numeric and cannot be zero {dynamicMsg} for this {category}.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										string targetType = string.IsNullOrEmpty(dtExcel.Rows[i]["TargetType"].ToString()) ? "" : dtExcel.Rows[i]["TargetType"].ToString();
										flag = targetType != "Accumulative" && targetType != "Maintenance";
										if (flag == true)
										{
											j++;
											msg += $"Wrong target type.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										string desireTo = string.IsNullOrEmpty(dtExcel.Rows[i]["DesiredTo"].ToString()) ? "" : dtExcel.Rows[i]["DesiredTo"].ToString();
										flag = desireTo != "Decrease" && desireTo != "Increase";
										if (flag == true)
										{
											j++;
											msg += $"Wrong desired to.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										double parseBaseline, baseline;
										string strBaseline = !string.IsNullOrEmpty(dtExcel.Rows[i]["Baseline"].ToString()) && double.TryParse(dtExcel.Rows[i]["Baseline"].ToString(), out parseBaseline) ? dtExcel.Rows[i]["Baseline"].ToString() : "";
										if (strBaseline == "")
										{
											j++;
											msg += $"Baseline cannot be empty and should be numbers only.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}
										else
										{
											baseline = Convert.ToDouble(dtExcel.Rows[i]["Baseline"].ToString());
										}

										double parseEndTarget, endTarget;
										string strEndTarget = !string.IsNullOrEmpty(dtExcel.Rows[i]["EndTarget"].ToString()) && double.TryParse(dtExcel.Rows[i]["EndTarget"].ToString(), out parseEndTarget) ? dtExcel.Rows[i]["EndTarget"].ToString() : "";
										if (strEndTarget == "")
										{
											j++;
											msg += $"End target cannot be empty or zero and should be numbers only.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}
										else
										{
											endTarget = Convert.ToDouble(dtExcel.Rows[i]["EndTarget"].ToString());
										}

										flag = (desireTo == "Increase" && endTarget <= baseline);
										if (flag == true)
										{
											j++;
											msg += $"When desire to value is increase than end target should be more than baseline.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										/*New*/
										flag = kpiType == "Initiative" && endTarget != 100 && baseline != 0 && targetType != "Accumulative" && desireTo == "Increase";
										if (flag == true)
										{
											j++;
											msg += $"When KPtype value is Initiative than end target should be 100, baseline should be 0, target type should be Accumulative and desireTo should be Increase.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}
										/*New*/

										flag = (desireTo == "Decrease" && endTarget >= baseline);
										if (flag == true)
										{
											j++;
											msg += $"When desire to value is decrease than end target should be less than baseline.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										int parseStart;
										int start = !string.IsNullOrEmpty(dtExcel.Rows[i]["Start"].ToString()) && int.TryParse(dtExcel.Rows[i]["Start"].ToString(), out parseStart) ? Convert.ToInt16(dtExcel.Rows[i]["Start"].ToString()) : 0;
										if (start == 0)
										{
											j++;
											msg += $"Start cannot be empty or zero and should be numbers only.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										int parseEnd;
										int end = !string.IsNullOrEmpty(dtExcel.Rows[i]["End"].ToString()) && int.TryParse(dtExcel.Rows[i]["End"].ToString(), out parseEnd) ? Convert.ToInt16(dtExcel.Rows[i]["End"].ToString()) : 0;
										if (end == 0)
										{
											j++;
											msg += $"End cannot be empty and should be numbers only.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										/*New*/
										flag = Convert.ToBoolean(itemCollectionCategory[0]["EndResultOverwrite"]) == true && (start != 4 || end != 4);
										if (flag == true)
										{
											j++;
											msg += $"{category} start and end should be Q4 only.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}
										/*New*/

										flag = start == 0 || start > end;
										if (flag == true)
										{
											j++;
											msg += $"Start cannot be zero or start cannot be greater end.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										string kpiDescription = !string.IsNullOrEmpty(dtExcel.Rows[i]["KPIDescription"].ToString()) ? dtExcel.Rows[i]["KPIDescription"].ToString() : "";
										string keyKPI = $"{employee}:{NormalizeKey(kpiDescription)}";
										SPList listkpiTypes = properties.Web.Lists.TryGetList("Types");
										SPListItemCollection itemCollectionkpiTypes = checkKPIType(listkpiTypes, kpiType, year);

										if (kpiDescription == "")
										{
											flag = true;
											j++;
											msg += $"KPI description cannot be empty.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										if (empIdKPIDescriptionHashSet.Contains(keyKPI) && Convert.ToBoolean(itemCollectionkpiTypes[0]["IsWorkStep"]) == false)
										{
											flag = true;
											j++;
											msg += $"KPI description is duplicate in the excel file.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}
										else
										{
											empIdKPIDescriptionHashSet.Add(keyKPI);
										}

										SPList listUserKPI = properties.Web.Lists.TryGetList("UserKPI");
										SPListItemCollection itemUserKPI = checkUserKPI(listUserKPI, Convert.ToInt32(itemCollectionContract[0].ID), kpiDescription);
										string workstepObjective = string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep Objective"].ToString()) ? "" : dtExcel.Rows[i]["WorkStep Objective"].ToString();

										if (itemUserKPI.Count > 0 && Convert.ToBoolean(itemCollectionkpiTypes[0]["IsWorkStep"]) == false)
										{
											flag = true;
											j++;
											msg += $"KPI description is already in use for current year contract.\r\n";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}
										else if (itemUserKPI.Count > 0 && Convert.ToBoolean(itemCollectionkpiTypes[0]["IsWorkStep"]) == true)
										{
											SPList workStep = properties.Web.Lists.TryGetList("WorkStep");
											SPListItemCollection itemWorkStep = checkWorkStep(workStep, itemUserKPI[0].ID, workstepObjective);

											if (itemWorkStep.Count > 0)
											{
												flag = true;
												j++;
												msg += $"WorkStep description is already in exists for current UserKPI {"KPI" + String.Format("{0:00000}", Convert.ToInt32(itemUserKPI[0].ID))}.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
												continue;
											}
										}

										int parseWorkstepStart, workstepStart = 0, parseWorkstepEnd, workstepEnd = 0;
										double parseWorkstepPercentage, workstepPercentage = 0;

										if (workstepObjective != "" && Convert.ToBoolean(itemCollectionkpiTypes[0]["IsWorkStep"]))
										{
											string keyKPIWS = $"{employee}:{NormalizeKey(kpiDescription)}:{NormalizeKey(workstepObjective)}";

											if (empIdKPIDescriptionWSObjectiveHashSet.Contains(keyKPIWS))
											{
												flag = true;
												j++;
												msg += $"KPI description and Workstep object is duplicate in the excel file.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
												continue;
											}
											else
											{
												empIdKPIDescriptionWSObjectiveHashSet.Add(keyKPIWS);
											}

											workstepPercentage = !string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep Percentage"].ToString()) && double.TryParse(dtExcel.Rows[i]["WorkStep Percentage"].ToString(), out parseWorkstepPercentage) ? Convert.ToDouble(dtExcel.Rows[i]["WorkStep Percentage"].ToString()) : 0;
											flag = workstepPercentage == 0 || workstepPercentage > 100;
											if (flag == true)
											{
												j++;
												msg += $"Percentage cannot be empty or zero or cannot be more than 100%.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
												continue;
											}

											workstepStart = !string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep Start"].ToString()) && int.TryParse(dtExcel.Rows[i]["WorkStep Start"].ToString(), out parseWorkstepStart) ? Convert.ToInt16(dtExcel.Rows[i]["WorkStep Start"].ToString()) : 0;
											if (workstepStart == 0)
											{
												j++;
												msg += $"Workstep start cannot be empty or zero and should be numbers only.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
												continue;
											}

											workstepEnd = !string.IsNullOrEmpty(dtExcel.Rows[i]["WorkStep End"].ToString()) && int.TryParse(dtExcel.Rows[i]["WorkStep End"].ToString(), out parseWorkstepEnd) ? Convert.ToInt16(dtExcel.Rows[i]["WorkStep End"].ToString()) : 0;
											if (workstepEnd == 0)
											{
												j++;
												msg += $"Workstep end cannot be empty or zero and should be numbers only.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
												continue;
											}

											flag = (workstepStart < start) || (workstepEnd > end) || (workstepStart > workstepEnd);
											if (flag == true)
											{
												j++;
												msg += $"Worksteps start and end should between or equal to UserKPI start and end.\r\n";
												dtExcel.Rows[i]["Errors"] = msg;

												updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
												continue;
											}
										}
										else if (workstepObjective == "" && Convert.ToBoolean(itemCollectionkpiTypes[0]["IsWorkStep"]))
										{
											j++;
											msg += $"This category needs worksteps.";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}
										else if (workstepObjective != "" && Convert.ToBoolean(itemCollectionkpiTypes[0]["IsWorkStep"]) == false)
										{
											j++;
											flag = workstepObjective == "";
											msg += $"Workstep objective is empty or {kpiType} cannot create worksteps.";
											dtExcel.Rows[i]["Errors"] = msg;

											updateBulkUploadlog(bulkUploadLog, dtExcel.Rows[i], currentItem.ID);
											continue;
										}

										if (flag == false) //Success
										{
											SPFieldLookupValue lookupContract = new SPFieldLookupValue(itemCollectionContract[0].ID, itemCollectionContract[0].Title);
											SPFieldLookupValue lookupCategory = new SPFieldLookupValue(itemCollectionCategory[0].ID, itemCollectionCategory[0].Title);
											SPFieldLookupValue lookupSubCategory = new SPFieldLookupValue(itemCollectionCategory[0].ID, Convert.ToString(itemCollectionCategory[0]["SubCategory"]));
											SPFieldLookupValue lookupKPIType = new SPFieldLookupValue(itemCollectionkpiTypes[0].ID, itemCollectionkpiTypes[0].Title);
											IDictionary<string, double> target = targetCaluculation(desireTo, targetType, endTarget, baseline, Convert.ToInt16(start), Convert.ToInt16(end));

											SPFieldLookupValue lookupUserKPIWorkStep;

											if (itemUserKPI.Count == 0)
											{
												SPListItem itemUserKPIToAdd = listUserKPI.AddItem();
												SPFieldLookupValue lookupEmployee = new SPFieldLookupValue(Convert.ToString(itemCollectionContract[0]["Employee"]));

												itemUserKPIToAdd["Contract"] = lookupContract;
												itemUserKPIToAdd["Category"] = lookupCategory;
												itemUserKPIToAdd["SubCategory"] = lookupSubCategory;
												itemUserKPIToAdd["KPIType"] = lookupKPIType;
												itemUserKPIToAdd["KPIDescription"] = kpiDescription;
												itemUserKPIToAdd["Weight"] = weight;
												itemUserKPIToAdd["Baseline"] = baseline;
												itemUserKPIToAdd["EndTarget"] = endTarget;
												itemUserKPIToAdd["TargetType"] = targetType;
												itemUserKPIToAdd["DesiredTo"] = desireTo;
												itemUserKPIToAdd["Start"] = start;
												itemUserKPIToAdd["End"] = end;
												itemUserKPIToAdd["isDeleted"] = false;
												itemUserKPIToAdd["TargetQ1"] = target["TargetQ1"];
												itemUserKPIToAdd["ActualQ1"] = null;
												itemUserKPIToAdd["PerformanceQ1"] = null;
												itemUserKPIToAdd["TargetQ2"] = target["TargetQ2"];
												itemUserKPIToAdd["ActualQ2"] = null;
												itemUserKPIToAdd["PerformanceQ2"] = null;
												itemUserKPIToAdd["TargetQ3"] = target["TargetQ3"];
												itemUserKPIToAdd["ActualQ3"] = null;
												itemUserKPIToAdd["PerformanceQ3"] = null;
												itemUserKPIToAdd["TargetQ4"] = target["TargetQ4"];
												itemUserKPIToAdd["ActualQ4"] = null;
												itemUserKPIToAdd["PerformanceQ4"] = null;
												itemUserKPIToAdd["IsCorporate"] = false;
