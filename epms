		/// <summary>
		/// An item is deleting.
		/// </summary>
		public override void ItemDeleting(SPItemEventProperties properties)
		{
			base.ItemDeleting(properties);
			SPSecurity.RunWithElevatedPrivileges(delegate ()
			{
				properties.Web.AllowUnsafeUpdates = true;

				using (SPWeb web = properties.OpenWeb())
				{
					try
					{
						SPListItem currentItem = properties.ListItem;

						if (currentItem == null)
						{
							return;
						}

						SPList listUserKPI = properties.Web.Lists.TryGetList("UserKPI");
						SPFieldLookupValue lookupContract = new SPFieldLookupValue(Convert.ToString(currentItem["Contract"]));
						SPListItemCollection itemsUserKPI = getUserKPI(listUserKPI, lookupContract.LookupId, currentItem.ID, true);

						SPList listContract = properties.Web.Lists.TryGetList("Contract");
						SPListItem itemContract = listContract.GetItemById(lookupContract.LookupId);
						SPFieldLookupValue lookupEmployee = new SPFieldLookupValue(Convert.ToString(itemContract["Employee"]));

						decimal kpiPerformanceQ1 = 0, kpiPerformanceQ2 = 0, kpiPerformanceQ3 = 0, kpiPerformanceQ4 = 0;
						decimal kpiCappingQ1 = 0, kpiCappingQ2 = 0, kpiCappingQ3 = 0, kpiCappingQ4 = 0;
						decimal endNegativeResult = 0;

						SPList listCategories = properties.Web.Lists.TryGetList("Categories");
						SPList listKPIType = properties.Web.Lists.TryGetList("Types");

						if (itemsUserKPI.Count == 1 || itemsUserKPI.Count == 0)
						{
							itemContract["PerformanceQ1"] = 0;
							itemContract["PerformanceQ2"] = 0;
							itemContract["PerformanceQ3"] = 0;
							itemContract["PerformanceQ4"] = 0;

							itemContract["EndNegativeResult"] = endNegativeResult;
							itemContract["EndYearResult"] = 0;
							itemContract.Update();
							return;
						}

						foreach (SPListItem itemUserKPI in itemsUserKPI)
						{
							SPFieldLookupValue category = new SPFieldLookupValue(Convert.ToString(itemUserKPI["Category"]));
							SPFieldLookupValue subcategory = new SPFieldLookupValue(Convert.ToString(itemUserKPI["SubCategory"]));
							SPFieldLookupValue kpiType = new SPFieldLookupValue(Convert.ToString(itemUserKPI["KPIType"]));

							SPFieldLookupValue year = new SPFieldLookupValue(Convert.ToString(itemContract["Year"]));

							SPListItemCollection itemsCategory = getCategory(listCategories, Convert.ToString(category.LookupValue), Convert.ToString(subcategory.LookupValue), Convert.ToString(year.LookupValue));
							SPListItem itemKPIType = listKPIType.GetItemById(kpiType.LookupId);

							int start = Convert.ToInt16(itemUserKPI["Start"]);
							int end = Convert.ToInt16(itemUserKPI["End"]);
							int performanceCapping = Convert.ToInt16(itemKPIType["PerformanceCapping"]);

							if (Convert.ToBoolean(itemUserKPI["IsCascade"]) && (Convert.ToString(itemContract["Status"]) == "New" || Convert.ToString(itemContract["Stage"]) == "Planning"))
							{
								SPListItemCollection itemsCascadeChildUserKPI = getChildUserKPIByCascadeParent(listUserKPI, itemUserKPI.ID);

								foreach (SPListItem itemCascadeChildUserKPI in itemsCascadeChildUserKPI)
								{
									using (EventReceiverManager eventReceiverManager = new EventReceiverManager(true))
									{
										SPFieldLookupValue lookupChildEmployee = new SPFieldLookupValue(Convert.ToString(itemCascadeChildUserKPI["Employee"]));
										SPListItemCollection itemChildContract = getContract(listContract, lookupChildEmployee.LookupId, Convert.ToString(itemCascadeChildUserKPI["Year"]));
										//=========== Do Only if Status not equal to New and Stage equal to Planning			
										if (Convert.ToString(itemChildContract[0]["Status"]) != "New" || Convert.ToString(itemChildContract[0]["Stage"]) != "Planning")
										{
											itemChildContract[0]["Status"] = "Return";
											itemChildContract[0]["Stage"] = "Planning";
											itemChildContract[0]["Period"] = "Initial";
											itemChildContract[0].Update();
										}
										//=============================================
									}
								}
							}

							bool endResultOverwrite = false;
							if (itemsCategory.Count > 0)
							{
								endResultOverwrite = Convert.ToBoolean(itemsCategory[0]["EndResultOverwrite"]);
							}

							if (endResultOverwrite == false)
							{
								if (start == 1 && (itemUserKPI["PerformanceQ1"] != null || Convert.ToDecimal(itemUserKPI["PerformanceQ1"]) != 0) && (itemUserKPI["ActualQ1"] != null || Convert.ToDecimal(itemUserKPI["ActualQ1"]) != 0)) // Q1
								{
									kpiPerformanceQ1 += (Convert.ToDecimal(itemUserKPI["PerformanceQ1"]) * Convert.ToDecimal(itemUserKPI["Weight"]));
									kpiCappingQ1 += (Convert.ToDecimal(performanceCapping) * Convert.ToDecimal(itemUserKPI["Weight"]));
								}

								if ((start <= 2) && (itemUserKPI["PerformanceQ2"] != null || Convert.ToDecimal(itemUserKPI["PerformanceQ2"]) != 0) && (itemUserKPI["ActualQ2"] != null || Convert.ToDecimal(itemUserKPI["ActualQ2"]) != 0)) // Q2
								{// && end >= 2
									kpiPerformanceQ2 += (Convert.ToDecimal(itemUserKPI["PerformanceQ2"]) * Convert.ToDecimal(itemUserKPI["Weight"]));
									kpiCappingQ2 += (Convert.ToDecimal(performanceCapping) * Convert.ToDecimal(itemUserKPI["Weight"]));
								}

								if ((start <= 3) && (itemUserKPI["PerformanceQ3"] != null || Convert.ToDecimal(itemUserKPI["PerformanceQ3"]) != 0) && (itemUserKPI["ActualQ3"] != null || Convert.ToDecimal(itemUserKPI["ActualQ3"]) != 0)) // Q3
								{// && end >= 3
									kpiPerformanceQ3 += (Convert.ToDecimal(itemUserKPI["PerformanceQ3"]) * Convert.ToDecimal(itemUserKPI["Weight"]));
									kpiCappingQ3 += (Convert.ToDecimal(performanceCapping) * Convert.ToDecimal(itemUserKPI["Weight"]));
								}

								if ((start <= 4) && (itemUserKPI["PerformanceQ4"] != null || Convert.ToDecimal(itemUserKPI["PerformanceQ4"]) != 0) && (itemUserKPI["ActualQ4"] != null || Convert.ToDecimal(itemUserKPI["ActualQ4"]) != 0)) // Q4
								{//&& end == 4
									kpiPerformanceQ4 += (Convert.ToDecimal(itemUserKPI["PerformanceQ4"]) * Convert.ToDecimal(itemUserKPI["Weight"]));
									kpiCappingQ4 += (Convert.ToDecimal(performanceCapping) * Convert.ToDecimal(itemUserKPI["Weight"]));
								}
							}
							else
							{
								endNegativeResult = itemUserKPI["PerformanceQ4"] == null || Convert.ToDecimal(itemUserKPI["PerformanceQ4"]) != 0 ? 0 : Convert.ToDecimal(itemUserKPI["Weight"]);
							}
						}

						decimal performanceQ1 = Math.Round(((kpiPerformanceQ1 / kpiCappingQ1) * 100), 2);
						decimal performanceQ2 = Math.Round(((kpiPerformanceQ2 / kpiCappingQ2) * 100), 2);
						decimal performanceQ3 = Math.Round(((kpiPerformanceQ3 / kpiCappingQ3) * 100), 2);
						decimal performanceQ4 = Math.Round(((kpiPerformanceQ4 / kpiCappingQ4) * 100), 2);

						itemContract["PerformanceQ1"] = Math.Round(performanceQ1, 2);
						itemContract["PerformanceQ2"] = Math.Round(performanceQ2, 2);
						itemContract["PerformanceQ3"] = Math.Round(performanceQ3, 2);
						itemContract["PerformanceQ4"] = Math.Round(performanceQ4, 2);

						itemContract["EndNegativeResult"] = endNegativeResult;
						itemContract["EndYearResult"] = Math.Round(((performanceQ1 + performanceQ2 + performanceQ3 + performanceQ4) / 4) - (endNegativeResult * -1), 2);

						using (EventReceiverManager eventReceiverManager = new EventReceiverManager(true))
						{
							itemContract.Update();
						}

						SPList listContractHistory = properties.Web.Lists.TryGetList("ContractHistory");

						SPListItem itemContractHistoryToAdd = listContractHistory.AddItem();

						itemContractHistoryToAdd["Contract"] = lookupContract;
						itemContractHistoryToAdd["Employee"] = lookupEmployee.LookupValue;
						itemContractHistoryToAdd["Year"] = itemContract["Year"];
						itemContractHistoryToAdd["Status"] = itemContract["Status"];
						itemContractHistoryToAdd["Stage"] = itemContract["Stage"];
						itemContractHistoryToAdd["Action"] = Convert.ToBoolean(currentItem["IsCorporate"]) ? "Corporate KPI - Deleted" : "User KPI - Deleted";
						itemContractHistoryToAdd["ActionBy"] = properties.Web.CurrentUser.Name;
						itemContractHistoryToAdd["KPIDescription"] = currentItem["KPIDescription"];
						itemContractHistoryToAdd["PerformanceQ1"] = Math.Round(performanceQ1, 2);
						itemContractHistoryToAdd["PerformanceQ2"] = Math.Round(performanceQ2, 2);
						itemContractHistoryToAdd["PerformanceQ3"] = Math.Round(performanceQ3, 2);
						itemContractHistoryToAdd["PerformanceQ4"] = Math.Round(performanceQ4, 2);
						itemContractHistoryToAdd["EndNegativeResult"] = endNegativeResult;
						itemContractHistoryToAdd["EndYearResult"] = Math.Round((performanceQ1 + performanceQ2 + performanceQ3 + performanceQ4) - (endNegativeResult * -1), 2);

						itemContractHistoryToAdd.Update();

						if (Convert.ToBoolean(currentItem["isDeleted"]) == true)
						{
							currentItem.Delete();
						}
					}
					catch (Exception ex)
					{
						LoggingService.LogError("EPMS Event Receiver Error", "EPMS UserKPI Item Deleting Event Receiver\n" + ex.ToString());
					}
				}
				properties.Web.AllowUnsafeUpdates = false;
			});
		}
		private SPListItemCollection getUserKPI(SPList listUserKPI, int ContractId, int userKPIID = 0, bool isDeleting = false)
		{
			SPListItemCollection itemCollectionUserKPI = null;
			string Query;
			if (isDeleting == false)
			{
				Query = $@"<Where>
											<And>
