.bbs-feature-card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 24px;
  margin-top: 10px;
}

.bbs-feature-card {
  background: #ffffff;
  border: 1px solid #dcdcdc;
  padding: 24px;
  cursor: pointer;
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  border-radius: 4px;
}

.bbs-feature-card:hover {
  transform: translateY(-3px);
  border-color: #c00000;
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
}

.bbs-feature-card-icon {
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  color: #c00000;
}

.bbs-feature-card-title {
  font-size: 16px;
  font-weight: 600;
  color: #222;
  margin-bottom: 8px;
}

.bbs-feature-card-desc {
  font-size: 13px;
  line-height: 1.5;
  color: #666;
}

.bbs-back-link {
  display: inline-block;
  margin-bottom: 16px;
  color: #c00000;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}

.bbs-back-link:hover {
  text-decoration: underline;
}


if (key === "learning-journey") {
  $("#bbsPageTitle").text("Learning Journey");
  $("#bbsContentArea").html(`
    <div class="bbs-card">
      <div class="bbs-back-link" id="bbsBackToLearning">← Back to My Learning</div>
      <h3 class="bbs-section-title">Learning Journey</h3>
      <p>Learning Journey content will appear here.</p>
    </div>
  `);

  $("#bbsBackToLearning").on("click", () => {
    $("#bbsPageTitle").text("My Learning");

    this.renderSectionCards("My Learning", [
      {
        key: "learning-journey",
        title: "Learning Journey",
        description: "Track your learning progress and development path.",
        iconSvg: `
          <svg viewBox="0 0 24 24" width="28" height="28">
            <path d="M4 4h16v16H4z" fill="none" stroke="#c00000" stroke-width="2"/>
          </svg>
        `
      },
      {
        key: "latest-training-opportunities",
        title: "Latest Training Opportunities",
        description: "Browse the latest available learning programs.",
        iconSvg: `
          <svg viewBox="0 0 24 24" width="28" height="28">
            <circle cx="12" cy="12" r="9" fill="none" stroke="#c00000" stroke-width="2"/>
          </svg>
        `
      },
      {
        key: "assignments",
        title: "Assignments",
        description: "Review pending and completed assignments.",
        iconSvg: `
          <svg viewBox="0 0 24 24" width="28" height="28">
            <path d="M6 4h12v16H6z" fill="none" stroke="#c00000" stroke-width="2"/>
          </svg>
        `
      },
      {
        key: "certificates",
        title: "Certificates",
        description: "Access issued course certificates.",
        iconSvg: `
          <svg viewBox="0 0 24 24" width="28" height="28">
            <polygon points="12,2 22,8 12,14 2,8" fill="none" stroke="#c00000" stroke-width="2"/>
          </svg>
        `
      }
    ]);

    this.bindSectionCards("learning");
  });

  return;
}

.bbs-card {
  background: #ffffff;
  border: 1px solid #dcdcdc;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
  padding: 40px;
  position: relative;
  z-index: 1;
}

.bbs-top-strip {
  height: 56px;
  display: flex;
  align-items: center;
  padding: 0 30px;
  border-bottom: 1px solid #dcdcdc;
  background: #edf0f3;
  position: sticky;
  top: 0;
  z-index: 30;
}

.bbs-subnav-wrap {
  background: #edf0f3;
  border-bottom: 1px solid #dcdcdc;
  position: sticky;
  top: 56px;
  z-index: 29;
}

.bbs-page-shell {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 120px);
  overflow: hidden;
}

.bbs-content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 30px;
  background: #edf0f3;
  position: relative;
  z-index: 1;
}