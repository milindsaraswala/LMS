.bbs-header-wrap {
  background: #edf0f3;
  border-bottom: 1px solid #dcdcdc;
  position: sticky;
  top: 0;
  z-index: 30;
  padding: 18px 30px 0 30px;
}

.bbs-header-title {
  font-size: 18px;
  font-weight: 600;
  color: #222;
  margin-bottom: 12px;
}

.bbs-subnav {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  gap: 28px;
  overflow-x: auto;
  white-space: nowrap;
}