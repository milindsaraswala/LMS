private showSectionCards(sectionKey: string): void {
  var config = this._sectionConfigs[sectionKey];

  if (!config) {
    return;
  }

  this.renderSectionCards(config.title, config.cards);
  this.bindSectionCards(sectionKey);
}

case "dashboard":
  $("#bbsPageTitle").text("Dashboard");
  this.showSectionCards("dashboard");
  break;

case "learning":
  $("#bbsPageTitle").text("My Learning");
  this.showSectionCards("learning");
  break;


private renderChildContentWithBack(
  parentSectionKey: string,
  pageTitle: string,
  sectionTitle: string,
  bodyHtml: string
): void {
  $("#bbsPageTitle").text(pageTitle);

  $("#bbsContentArea").html(`
    <div class="bbs-card">
      <div class="bbs-back-link" id="bbsBackLink">← Back</div>
      <h3 class="bbs-section-title">${sectionTitle}</h3>
      ${bodyHtml}
    </div>
  `);

  $("#bbsBackLink").on("click", () => {
    $("#bbsPageTitle").text(this._sectionConfigs[parentSectionKey].title);
    this.showSectionCards(parentSectionKey);
  });
}

private loadChildCardContent(parentView: string, key: string): void {

  if (parentView === "learning") {

    if (key === "learning-journey") {
      this.renderChildContentWithBack(
        "learning",
        "Learning Journey",
        "Learning Journey",
        `<p>Learning Journey content will appear here.</p>`
      );
      return;
    }

    if (key === "latest-training-opportunities") {
      this.renderChildContentWithBack(
        "learning",
        "Latest Training Opportunities",
        "Latest Training Opportunities",
        `<p>Latest training opportunities content will appear here.</p>`
      );
      return;
    }

    if (key === "assignments") {
      this.renderChildContentWithBack(
        "learning",
        "Assignments",
        "Assignments",
        `<p>Assignments content will appear here.</p>`
      );
      return;
    }

    if (key === "certificates") {
      this.renderChildContentWithBack(
        "learning",
        "Certificates",
        "Certificates",
        `<p>Certificates content will appear here.</p>`
      );
      return;
    }
  }

  if (parentView === "dashboard") {

    if (key === "dashboard-overview") {
      this.renderChildContentWithBack(
        "dashboard",
        "Overview",
        "Overview",
        `<p>Dashboard overview content will appear here.</p>`
      );
      return;
    }

    if (key === "dashboard-reports") {
      this.renderChildContentWithBack(
        "dashboard",
        "Reports",
        "Reports",
        `<p>Reports content will appear here.</p>`
      );
      return;
    }
  }
}

.bbs-feature-card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 24px;
  margin-top: 10px;
}

.bbs-feature-card {
  background: #ffffff;
  border: 1px solid #dcdcdc;
  padding: 24px;
  cursor: pointer;
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  border-radius: 4px;
}

.bbs-feature-card:hover {
  transform: translateY(-3px);
  border-color: #c00000;
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
}

.bbs-feature-card-icon {
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  color: #c00000;
}

.bbs-feature-card-title {
  font-size: 16px;
  font-weight: 600;
  color: #222;
  margin-bottom: 8px;
}

.bbs-feature-card-desc {
  font-size: 13px;
  line-height: 1.5;
  color: #666;
}

.bbs-back-link {
  display: inline-block;
  margin-bottom: 16px;
  color: #c00000;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}

.bbs-back-link:hover {
  text-decoration: underline;
}