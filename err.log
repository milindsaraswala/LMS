/// <reference path="../../../node_modules/@types/devextreme/dx.all.d.ts"/>
import { SPComponentLoader } from "@microsoft/sp-loader";
import {
  BaseClientSideWebPart,
  IPropertyPaneConfiguration,
  PropertyPaneTextField
} from "@microsoft/sp-webpart-base";
import * as $ from "jquery";

import { sp } from "@pnp/sp/presets/all";
import * as strings from "BusinessSchoolDashboardWebPartStrings";

require("../../assets/dashboardStyle.css");

export interface IBusinessSchoolDashboardWebPartProps {
  description: string;
}

export default class BusinessSchoolDashboardWebPart extends BaseClientSideWebPart<IBusinessSchoolDashboardWebPartProps> {
  public async onInit(): Promise<void> {
    await super.onInit();
    SPComponentLoader.loadCss("/CDN/devExtreme/21.2.13/css/dx.light.css");

    sp.setup({
      spfxContext: this.context,
    });
  }

  public render(): void {
    this.domElement.innerHTML = `
    <div class="bbs-layout">
      <div class="bbs-page-shell">

        <div class="bbs-top-strip">
          <h2 id="bbsPageTitle">About</h2>
        </div>

        <div class="bbs-subnav-wrap">
          <ul id="bbsMenu" class="bbs-subnav">
            <li data-view="about" class="active">About</li>
            <li data-view="dashboard">Dashboard</li>
            <li data-view="learning">My Learning</li>
            <li data-view="required">Required Actions</li>
            <li data-view="competencies">Competencies & Development</li>
            <li data-view="communication">Communication & Feedback</li>
            <li data-view="account">Account Settings</li>
          </ul>
        </div>

        <div class="bbs-content" id="bbsContentArea"></div>

      </div>
    </div>
  `;

    this.initializeNavigation();
  }

  protected getPropertyPaneConfiguration(): IPropertyPaneConfiguration {
    return {
      pages: [
        {
          header: {
            description: strings.PropertyPaneDescription
          },
          groups: [
            {
              groupName: strings.BasicGroupName,
              groupFields: [
                PropertyPaneTextField("description", {
                  label: strings.DescriptionFieldLabel
                })
              ]
            }
          ]
        }
      ]
    };
  }

  private initializeNavigation(): void {

    const loadView = async (view: string) => {
      $("#bbsContentArea").html("");

      switch (view) {
        case "about":
          $("#bbsPageTitle").text("About");
          $("#bbsContentArea").html(`
          <div class="bbs-card">
            <div class="bbs-card-inner">
              <div class="bbs-card-left">
                <h1 class="bbs-title">Boubyan Business School</h1>
                <p>
                  Boubyan Business School comprises of five main educational and training schools
                  that aim to develop our employees’ skills and abilities in various banking areas,
                  while helping them acquire diverse skillsets.
                </p>
                <p>
                  The five main schools serve as an umbrella for a number of other specialized academies
                  focusing on all technical areas of the banking business to help accelerate digital and
                  technological transformation.
                </p>
                <div class="bbs-btn-wrapper">
                  <button class="bbs-primary-btn">Apply Now</button>
                </div>
              </div>
              <div class="bbs-card-right">
                <img src="/CDN/images/genrci%20banner.jpg" />
              </div>
            </div>
          </div>
        `);
          break;

        case "dashboard":
          $("#bbsPageTitle").text("Dashboard");
          $("#bbsContentArea").html(`
          <div class="bbs-grid-wrapper">
            <div id="dashboardGrid"></div>
          </div>
        `);
          // this.renderDashboardGrid();
          break;

        case "learning":
          $("#bbsPageTitle").text("My Learning");

          this.renderSectionCards("My Learning", [
            {
              key: "learning-journey",
              title: "Learning Journey",
              description: "Track your learning progress and development path.",
              iconSvg: `
        <svg viewBox="0 0 24 24" width="28" height="28">
          <path d="M4 4h16v16H4z" fill="none" stroke="#c00000" stroke-width="2"/>
        </svg>
      `
            },
            {
              key: "latest-training-opportunities",
              title: "Latest Training Opportunities",
              description: "Browse the latest available learning programs.",
              iconSvg: `
        <svg viewBox="0 0 24 24" width="28" height="28">
          <circle cx="12" cy="12" r="9" fill="none" stroke="#c00000" stroke-width="2"/>
        </svg>
      `
            },
            {
              key: "assignments",
              title: "Assignments",
              description: "Review pending and completed assignments.",
              iconSvg: `
        <svg viewBox="0 0 24 24" width="28" height="28">
          <path d="M6 4h12v16H6z" fill="none" stroke="#c00000" stroke-width="2"/>
        </svg>
      `
            },
            {
              key: "certificates",
              title: "Certificates",
              description: "Access issued course certificates.",
              iconSvg: `
        <svg viewBox="0 0 24 24" width="28" height="28">
          <polygon points="12,2 22,8 12,14 2,8" fill="none" stroke="#c00000" stroke-width="2"/>
        </svg>
      `
            }
          ]);

          this.bindSectionCards("learning");
          break;

        case "required":
          $("#bbsPageTitle").text("Required Actions");
          $("#bbsContentArea").html(`
          <div class="bbs-card">
            <h3 class="bbs-section-title">Required Actions</h3>
            <p>Required actions content will appear here.</p>
          </div>
        `);
          break;

        case "competencies":
          $("#bbsPageTitle").text("Competencies & Development");
          $("#bbsContentArea").html(`
          <div class="bbs-card">
            <h3 class="bbs-section-title">Competencies & Development</h3>
            <p>Competencies content will appear here.</p>
          </div>
        `);
          break;

        case "communication":
          $("#bbsPageTitle").text("Communication & Feedback");
          $("#bbsContentArea").html(`
          <div class="bbs-card">
            <div class="bbs-settings-wrapper">
              <div class="bbs-settings-section">
                <h3 class="bbs-section-title">Announcements</h3>
                <div id="bbsAnnouncementsPreview"></div>
                <div class="bbs-announcement-footer">
                  <button id="bbsViewAllNews" class="bbs-secondary-btn">View All</button>
                </div>
              </div>

              <div class="bbs-settings-section">
                <h3 class="bbs-section-title">Your Course Reviews</h3>
                <div id="bbsReviewsGrid"></div>
              </div>
            </div>
          </div>
        `);
          this.renderAnnouncementsPreview();
          // this.renderReviews();
          this.bindViewAllNews();
          break;

        case "account":
          $("#bbsPageTitle").text("Account Settings");
          $("#bbsContentArea").html(`
          <div class="bbs-card">
            <div class="bbs-settings-wrapper">

              <div class="bbs-settings-section">
                <h3 class="bbs-section-title">Profile Photo</h3>
                <div class="bbs-photo-row">
                  <div class="bbs-avatar-circle">
                    <span id="bbsInitials">MS</span>
                  </div>
                  <div class="bbs-photo-actions">
                    <label class="bbs-file-label">
                      Choose Photo
                      <input type="file" id="profilePhotoUpload" accept="image/*" hidden />
                    </label>
                    <button id="savePhotoBtn" class="bbs-primary-btn">Update Photo</button>
                  </div>
                </div>
              </div>

              <div class="bbs-settings-section">
                <h3 class="bbs-section-title">Personal Details</h3>
                <div class="bbs-form-row">
                  <label>Full Name</label>
                  <input type="text" id="profileFullName" disabled />
                </div>
                <div class="bbs-form-row">
                  <label>Email</label>
                  <input type="text" id="profileEmail" disabled />
                </div>
                <div class="bbs-form-row">
                  <label>Department</label>
                  <input type="text" id="profileDepartment" disabled />
                </div>
              </div>

              <div class="bbs-settings-section">
                <h3 class="bbs-section-title">Preferred Language</h3>
                <div class="bbs-radio-group">
                  <label><input type="radio" name="language" value="en" checked /> English</label>
                  <label><input type="radio" name="language" value="ar" /> Arabic</label>
                </div>
              </div>

              <div class="bbs-settings-section">
                <h3 class="bbs-section-title">Notification Settings</h3>
                <div class="bbs-checkbox-group">
                  <label><input type="checkbox" value="email" checked /> Email</label>
                  <label><input type="checkbox" value="whatsapp" /> WhatsApp</label>
                  <label><input type="checkbox" value="push" /> Push Notifications</label>
                </div>
              </div>

              <div class="bbs-btn-wrapper">
                <button id="saveSettingsBtn" class="bbs-primary-btn">Save Settings</button>
              </div>

            </div>
          </div>
        `);
          this.initializeAccountSettings();
          break;
      }
    };

    $("#bbsMenu").off("click").on("click", "li", function () {
      $("#bbsMenu li").removeClass("active");
      $(this).addClass("active");

      const view = $(this).attr("data-view");
      if (view) {
        loadView(view);
      }
    });

    loadView("about");
  }

  private initializeAccountSettings(): void {

    const user = this.context.pageContext.user;

    $("#profileFullName").val(user.displayName);
    $("#profileEmail").val(user.email);
    $("#profileDepartment").val("Banking Operations"); // replace with real API later

    const initials = user.displayName
      .split(" ")
      .map(n => n[0])
      .join("")
      .substring(0, 2)
      .toUpperCase();

    $("#bbsInitials").text(initials);

    $("#saveSettingsBtn").on("click", () => {

      const language = $("input[name='language']:checked").val();

      const notifications: string[] = [];
      $(".bbs-checkbox-group input:checked").each(function () {
        notifications.push($(this).val() as string);
      });

      const payload = {
        language,
        notifications
      };

      console.log("Saving settings:", payload);

      alert("Settings saved successfully");
    });
  }

  private async renderAnnouncementsPreview(): Promise<void> {
    const newsItems = await sp.web.lists.getByTitle("Site Pages").items.expand("Editor")
      .select("*", "Editor/Title", "Editor/UserName", "FileRef").filter("PromotedState eq '2'").orderBy("ReleaseDate", false).top(5).get();

    let html = `<div class="bbs-announcement-grid">`;

    newsItems.forEach((item: any) => {

      let banner = "";

      if (item.BannerImageUrl) {
        if (typeof item.BannerImageUrl === "string") {
          try {
            const parsed = JSON.parse(item.BannerImageUrl);
            banner = parsed.serverRelativeUrl || parsed.Url || "";
          } catch (e) {
            banner = item.BannerImageUrl;
          }
        } else if (item.BannerImageUrl.Url) {
          banner = item.BannerImageUrl.Url;
        }
      }

      const title = item.Title;
      const desc = item.Description ? item.Description : "";
      const modifiedBy = item.Editor && item.Editor.Title ? item.Editor.Title : "";
      const date = new Date(item.FirstPublishedDate).toLocaleDateString();
      const newsUrl = item.FileRef;

      html += `
      <div class="bbs-announcement-card" data-url="${newsUrl}">
        ${banner ? `<div class="bbs-announcement-image">
            <img src="${banner}" />
          </div>` : ""}
        <div class="bbs-announcement-content">
          <h4>${title}</h4>
          <p class="bbs-announcement-desc">${desc}</p>
          <div class="bbs-announcement-meta">
            <span>Published: ${date}</span>
            <span>Modified By: ${modifiedBy}</span>
          </div>
        </div>
      </div>
    `;
    });

    html += `</div>`;

    $("#bbsAnnouncementsPreview").html(html);
    $(".bbs-announcement-card").on("click", function () {
      const url = $(this).data("url");
      window.location.href = url;
    });
  }

  private bindViewAllNews(): void {
    $("#bbsViewAllNews").on("click", () => {
      window.location.href =
        this.context.pageContext.web.absoluteUrl + "/SitePages/Forms/ByAuthor.aspx";
      // Replace with your news page link if different
    });
  }

  private renderSectionCards(
    title: string,
    cards: Array<{
      key: string;
      title: string;
      description: string;
      iconSvg: string;
    }>
  ): void {
    let html = `
    <div class="bbs-card">
      <h3 class="bbs-section-title">${title}</h3>
      <div class="bbs-feature-card-grid">
  `;

    cards.forEach((card) => {
      html += `
      <div class="bbs-feature-card" data-key="${card.key}">
        <div class="bbs-feature-card-icon">
          ${card.iconSvg}
        </div>
        <div class="bbs-feature-card-title">${card.title}</div>
        <div class="bbs-feature-card-desc">${card.description}</div>
      </div>
    `;
    });

    html += `
      </div>
    </div>
  `;

    $("#bbsContentArea").html(html);
  }

  private bindSectionCards(parentView: string): void {
    $("#bbsContentArea").off("click", ".bbs-feature-card");

    $("#bbsContentArea").on("click", ".bbs-feature-card", (e) => {
      const key = $(e.currentTarget).attr("data-key");

      if (!key) {
        return;
      }

      this.loadChildCardContent(parentView, key);
    });
  }

  private loadChildCardContent(parentView: string, key: string): void {

    if (parentView === "learning") {

      if (key === "learning-journey") {
        $("#bbsPageTitle").text("Learning Journey");
        $("#bbsContentArea").html(`
        <div class="bbs-card">
          <h3 class="bbs-section-title">Learning Journey</h3>
          <p>Learning Journey content will appear here.</p>
        </div>
      `);
        return;
      }

      if (key === "latest-training-opportunities") {
        $("#bbsPageTitle").text("Latest Training Opportunities");
        $("#bbsContentArea").html(`
        <div class="bbs-card">
          <h3 class="bbs-section-title">Latest Training Opportunities</h3>
          <p>Latest training opportunities content will appear here.</p>
        </div>
      `);
        return;
      }

      if (key === "assignments") {
        $("#bbsPageTitle").text("Assignments");
        $("#bbsContentArea").html(`
        <div class="bbs-card">
          <h3 class="bbs-section-title">Assignments</h3>
          <p>Assignments content will appear here.</p>
        </div>
      `);
        return;
      }

      if (key === "certificates") {
        $("#bbsPageTitle").text("Certificates");
        $("#bbsContentArea").html(`
        <div class="bbs-card">
          <h3 class="bbs-section-title">Certificates</h3>
          <p>Certificates content will appear here.</p>
        </div>
      `);
        return;
      }
    }

    if (parentView === "dashboard") {

      if (key === "analytics") {
        $("#bbsPageTitle").text("Analytics");
        $("#bbsContentArea").html(`
        <div class="bbs-card">
          <h3 class="bbs-section-title">Analytics</h3>
          <p>Analytics content will appear here.</p>
        </div>
      `);
        return;
      }

      if (key === "reports") {
        $("#bbsPageTitle").text("Reports");
        $("#bbsContentArea").html(`
        <div class="bbs-card">
          <h3 class="bbs-section-title">Reports</h3>
          <p>Reports content will appear here.</p>
        </div>
      `);
        return;
      }
    }
  }
}



==============================CSS===============

.bbs-layout {
  width: 100%;
  min-height: calc(100vh - 120px);
  background: #edf0f3;
  font-family: "Segoe UI", Arial, sans-serif;
}

.bbs-page-shell {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 120px);
}

.bbs-top-strip {
  height: 56px;
  display: flex;
  align-items: center;
  padding: 0 30px;
  border-bottom: 1px solid #dcdcdc;
  background: #edf0f3;
  position: sticky;
  top: 0;
  z-index: 20;
}

.bbs-top-strip h2 {
  margin: 0;
  font-size: 18px;
  font-weight: 600;
  color: #222;
}

.bbs-subnav-wrap {
  background: #edf0f3;
  border-bottom: 1px solid #dcdcdc;
  position: sticky;
  top: 56px;
  z-index: 19;
}

.bbs-subnav {
  list-style: none;
  margin: 0;
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 28px;
  overflow-x: auto;
  white-space: nowrap;
}

.bbs-subnav li {
  position: relative;
  padding: 16px 0 14px 0;
  font-size: 14px;
  color: #444;
  cursor: pointer;
  transition: color 0.2s ease;
}

.bbs-subnav li:hover {
  color: #c00000;
}

.bbs-subnav li.active {
  color: #c00000;
  font-weight: 600;
}

.bbs-subnav li.active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1px;
  height: 2px;
  background: #c00000;
  border-radius: 2px;
}

.bbs-content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 30px;
  background: #edf0f3;
}

/* thin horizontal scrollbar for menu */
.bbs-subnav::-webkit-scrollbar {
  height: 6px;
}

.bbs-subnav::-webkit-scrollbar-track {
  background: transparent;
}

.bbs-subnav::-webkit-scrollbar-thumb {
  background: transparent;
  border-radius: 10px;
}

.bbs-subnav:hover::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.2);
}

.bbs-card {
