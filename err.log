case "communication":

  $(".bbs-top-strip").html("<h2>Communication & Feedback</h2>");

  $("#bbsContentArea").html(`
    <div class="bbs-card">

      <div class="bbs-settings-wrapper">

        <div class="bbs-settings-section">
          <h3 class="bbs-section-title">Announcements</h3>
          <div id="bbsAnnouncementsPreview"></div>
          <div class="bbs-announcement-footer">
            <button id="bbsViewAllNews" class="bbs-secondary-btn">
              View All
            </button>
          </div>
        </div>

        <div class="bbs-settings-section">
          <h3 class="bbs-section-title">Your Course Reviews</h3>
          <div id="bbsReviewsGrid"></div>
        </div>

      </div>

    </div>
  `);

  this.renderAnnouncementsPreview();
  this.renderReviews();
  this.bindViewAllNews();

  break;

private async renderAnnouncementsPreview(): Promise<void> {

  const newsItems = await this.context.spHttpClient.get(
    `${this.context.pageContext.web.absoluteUrl}/_api/web/lists/getbytitle('Site Pages')/items?$filter=PromotedState eq 2&$orderby=FirstPublishedDate desc&$top=3`,
    SPHttpClient.configurations.v1
  );

  const response = await newsItems.json();

  let html = `<div class="bbs-announcement-grid">`;

  response.value.forEach((item: any) => {

    const newsUrl = item.FileRef;
    const title = item.Title;
    const date = new Date(item.FirstPublishedDate).toLocaleDateString();

    html += `
      <div class="bbs-announcement-card" data-url="${newsUrl}">
        <h4>${title}</h4>
        <div class="bbs-announcement-date">${date}</div>
      </div>
    `;
  });

  html += `</div>`;

  $("#bbsAnnouncementsPreview").html(html);

  $(".bbs-announcement-card").on("click", function () {
    const url = $(this).data("url");
    window.location.href = url;
  });
}

private bindViewAllNews(): void {

  $("#bbsViewAllNews").on("click", () => {
    window.location.href =
      this.context.pageContext.web.absoluteUrl + "/SitePages/Forms/ByAuthor.aspx"; 
    // Replace with your news page link if different
  });

}

.bbs-announcement-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}

.bbs-announcement-card {
  background: #ffffff;
  border: 1px solid #e5e5e5;
  padding: 20px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.bbs-announcement-card:hover {
  border-color: #c00000;
  box-shadow: 0 3px 8px rgba(0,0,0,0.05);
}

.bbs-announcement-card h4 {
  margin: 0 0 10px 0;
  font-size: 15px;
  font-weight: 600;
  color: #222;
}

.bbs-announcement-date {
  font-size: 12px;
  color: #777;
}

.bbs-announcement-footer {
  margin-top: 20px;
  text-align: right;
}
