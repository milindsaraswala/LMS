private showSectionCards(sectionKey: string): void {
  var config = this._sectionConfigs[sectionKey];

  if (!config) {
    return;
  }

  this.renderSectionCards(config.title, config.cards);
  this.bindSectionCards(sectionKey);
}

case "dashboard":
  $("#bbsPageTitle").text("Dashboard");
  this.showSectionCards("dashboard");
  break;

case "learning":
  $("#bbsPageTitle").text("My Learning");
  this.showSectionCards("learning");
  break;

case "required":
  $("#bbsPageTitle").text("Required Actions");
  this.showSectionCards("required");
  break;

case "communication":
  $("#bbsPageTitle").text("Communication & Feedback");
  this.showSectionCards("communication");
  break;


private loadChildCardContent(parentView: string, key: string): void {

  if (parentView === "dashboard") {

    if (key === "dashboard-pending-assignments") {
      this.renderChildContentWithBack(
        "dashboard",
        "Pending Assignments",
        "Pending Assignments",
        `<p>Pending assignments with their status will appear here.</p>`
      );
      return;
    }

    if (key === "dashboard-upcoming-trainings") {
      this.renderChildContentWithBack(
        "dashboard",
        "Upcoming Trainings",
        "Upcoming Trainings",
        `<p>Upcoming trainings content will appear here.</p>`
      );
      return;
    }

    if (key === "dashboard-pending-evaluations") {
      this.renderChildContentWithBack(
        "dashboard",
        "Pending Evaluations",
        "Pending Evaluations",
        `<p>Pending evaluations content will appear here.</p>`
      );
      return;
    }
  }

  if (parentView === "learning") {

    if (key === "learning-journey") {
      this.renderChildContentWithBack(
        "learning",
        "Learning Journey",
        "Learning Journey",
        `<p>Full training history will appear here.</p>`
      );
      return;
    }

    if (key === "latest-training-opportunities") {
      this.renderChildContentWithBack(
        "learning",
        "Latest Training Opportunities",
        "Latest Training Opportunities",
        `<p>List of all courses the user can apply to will appear here.</p>`
      );
      return;
    }

    if (key === "learning-assignments") {
      this.renderChildContentWithBack(
        "learning",
        "Assignments",
        "Assignments",
        `<p>Pending and completed assignments will appear here.</p>`
      );
      return;
    }

    if (key === "learning-certificates") {
      this.renderChildContentWithBack(
        "learning",
        "Certificates",
        "Certificates",
        `<p>Staff certifications available for download will appear here.</p>`
      );
      return;
    }
  }

  if (parentView === "required") {

    if (key === "required-assessment") {
      this.renderChildContentWithBack(
        "required",
        "Required Assessment",
        "Required Assessment",
        `<p>Required assessments such as CBK, AML, and InfoSec will appear here.</p>`
      );
      return;
    }

    if (key === "required-training-evaluations") {
      this.renderChildContentWithBack(
        "required",
        "Training Evaluations",
        "Training Evaluations",
        `<p>Evaluations pending from completed courses will appear here.</p>`
      );
      return;
    }
  }

  if (parentView === "communication") {

    if (key === "communication-announcements") {
      this.renderChildContentWithBack(
        "communication",
        "Announcements",
        "Announcements",
        `<div id="bbsAnnouncementsPreview"></div>
         <div class="bbs-announcement-footer">
           <button id="bbsViewAllNews" class="bbs-secondary-btn">View All</button>
         </div>`
      );

      this.renderAnnouncementsPreview();
      this.bindViewAllNews();
      return;
    }

    if (key === "communication-reviews") {
      this.renderChildContentWithBack(
        "communication",
        "Reviews",
        "Reviews",
        `<div id="bbsReviewsGrid"></div>`
      );

      // this.renderReviews();
      return;
    }
  }
}

private renderChildContentWithBack(
  parentSectionKey: string,
  pageTitle: string,
  sectionTitle: string,
  bodyHtml: string
): void {
  $("#bbsPageTitle").text(pageTitle);

  $("#bbsContentArea").html(`
    <div class="bbs-card">
      <div class="bbs-back-link" id="bbsBackLink">← Back</div>
      <h3 class="bbs-section-title">${sectionTitle}</h3>
      ${bodyHtml}
    </div>
  `);

  $("#bbsBackLink").on("click", () => {
    $("#bbsPageTitle").text(this._sectionConfigs[parentSectionKey].title);
    this.showSectionCards(parentSectionKey);
  });
}

.bbs-feature-card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 24px;
  margin-top: 10px;
}

.bbs-feature-card {
  background: #ffffff;
  border: 1px solid #dcdcdc;
  border-radius: 4px;
  padding: 24px;
  cursor: pointer;
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.bbs-feature-card:hover {
  transform: translateY(-3px);
  border-color: #c00000;
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
}

.bbs-feature-card-icon {
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  color: #c00000;
}

.bbs-feature-card-title {
  font-size: 16px;
  font-weight: 600;
  color: #222;
  margin-bottom: 8px;
}

.bbs-feature-card-desc {
  font-size: 13px;
  line-height: 1.5;
  color: #666;
}

.bbs-back-link {
  display: inline-block;
  margin-bottom: 16px;
  color: #c00000;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}

.bbs-back-link:hover {
  text-decoration: underline;
}







