.bbs-layout {
  width: 100%;
  min-height: calc(100vh - 120px);
  background: #edf0f3;
  font-family: "Segoe UI", Arial, sans-serif;
}

.bbs-top-strip {
  height: 56px;
  display: flex;
  align-items: center;
  padding: 0 30px;
  border-bottom: 1px solid #dcdcdc;
  background: #edf0f3;
  position: sticky;
  top: 0;
  z-index: 30;
}

.bbs-top-strip h2 {
  margin: 0;
  font-size: 18px;
  font-weight: 600;
  color: #222;
}

.bbs-subnav-wrap {
  background: #edf0f3;
  border-bottom: 1px solid #dcdcdc;
  position: sticky;
  top: 56px;
  z-index: 29;
}

.bbs-subnav {
  list-style: none;
  margin: 0;
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 28px;
  overflow-x: auto;
  white-space: nowrap;
}

.bbs-subnav li {
  position: relative;
  padding: 16px 0 14px 0;
  font-size: 14px;
  color: #444;
  cursor: pointer;
  transition: color 0.2s ease;
}

.bbs-subnav li:hover {
  color: #c00000;
}

.bbs-subnav li.active {
  color: #c00000;
  font-weight: 600;
}

.bbs-subnav li.active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1px;
  height: 2px;
  background: #c00000;
  border-radius: 2px;
}

/* thin horizontal scrollbar for menu */
.bbs-subnav::-webkit-scrollbar {
  height: 6px;
}

.bbs-subnav::-webkit-scrollbar-track {
  background: transparent;
}

.bbs-subnav::-webkit-scrollbar-thumb {
  background: transparent;
  border-radius: 10px;
}

.bbs-subnav:hover::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.2);
}

.bbs-card {
  background: #ffffff;
  border: 1px solid #dcdcdc;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
  padding: 40px;
  position: relative;
  z-index: 1;
  max-width: 980px;
  margin: 0 auto;
}

.bbs-card-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}

.bbs-card-left {
  flex: 0 0 60%;
}

.bbs-title {
  font-size: 28px;
  font-weight: 500;
  color: #222;
  margin-bottom: 20px;
}

.bbs-card-left p {
  font-size: 14px;
  line-height: 1.6;
  color: #555;
  margin-bottom: 15px;
}

.bbs-primary-btn {
  background: #c00000;
  color: #ffffff;
  border: none;
  min-width: 120px;
  height: 36px;
  padding: 0 22px;
  font-size: 13px;
  cursor: pointer;
  border-radius: 3px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.bbs-primary-btn:hover {
  background: #a00000;
}

.bbs-card-right {
  flex: 0 0 40%;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: right;
}

.bbs-card-right img {
  max-width: 420px;
  width: 100%;
  height: auto;
}

.bbs-btn-wrapper {
  display: flex;
  justify-content: flex-end;
  margin-top: 20px;
}

.bbs-grid-wrapper {
  background: #ffffff;
  border: 1px solid #dcdcdc;
  padding: 20px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
}

.bbs-avatar-circle {
  width: 90px;
  height: 90px;
  background: #c00000;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.bbs-avatar-circle span {
  font-size: 32px;
  color: #ffffff;
  font-weight: 600;
}

.bbs-secondary-btn {
  background: #ffffff;
  border: 1px solid #c00000;
  color: #c00000;
  padding: 6px 18px;
  font-size: 13px;
  cursor: pointer;
  border-radius: 2px;
}

.bbs-secondary-btn:hover {
  background: #c00000;
  color: #ffffff;
}

.bbs-settings-section:last-child {
  border-bottom: none;
}

.bbs-section-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 20px;
  color: #222;
}

.bbs-photo-row {
  display: flex;
  align-items: center;
  gap: 25px;
}

.bbs-photo-actions {
  display: flex;
  gap: 12px;
}

.bbs-file-label,
.bbs-primary-btn {
  height: 36px;
  min-width: 120px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.bbs-announcement-date {
  font-size: 12px;
  color: #777;
}

.bbs-announcement-footer {
  margin-top: 20px;
  text-align: right;
}

.bbs-announcement-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 25px;
}

.bbs-announcement-card {
  background: #ffffff;
  border: 1px solid #e5e5e5;
  cursor: pointer;
  transition: all 0.2s ease;
  display: flex;
  flex-direction: column;
}

.bbs-announcement-card:hover {
  border-color: #c00000;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.06);
}

.bbs-announcement-image img {
  width: 100%;
  height: 160px;
  object-fit: cover;
}

.bbs-announcement-content {
  padding: 18px;
}

.bbs-announcement-content h4 {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 10px;
  color: #222;
}

.bbs-announcement-desc {
  font-size: 13px;
  color: #555;
  margin-bottom: 15px;
  line-height: 1.5;
}

.bbs-announcement-meta {
  font-size: 12px;
  color: #777;
  display: flex;
  justify-content: space-between;
}

.bbs-page-shell {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 120px);
  overflow: hidden;
}

.bbs-content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 30px;
  background: #edf0f3;
  position: relative;
  z-index: 1;
}

.bbs-feature-card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 24px;
  margin-top: 10px;
}

.bbs-feature-card {
  background: #ffffff;
  border: 1px solid #dcdcdc;
  border-radius: 4px;
  padding: 24px;
  cursor: pointer;
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.bbs-feature-card:hover {
  transform: translateY(-3px);
  border-color: #c00000;
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
}

.bbs-feature-card-icon {
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  color: #c00000;
}

.bbs-feature-card-title {
  font-size: 16px;
  font-weight: 600;
  color: #222;
  margin-bottom: 8px;
}

.bbs-feature-card-desc {
  font-size: 13px;
  line-height: 1.5;
  color: #666;
}

.bbs-back-link {
  display: inline-block;
  margin-bottom: 16px;
  color: #c00000;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}

.bbs-back-link:hover {
  text-decoration: underline;
}

.bbs-profile-label {
  font-size: 13px;
  font-weight: 600;
  color: #555;
}

.bbs-profile-value {
  font-size: 14px;
  color: #222;
}

.bbs-account-header {
  display: grid;
  grid-template-columns: 110px 1fr auto;
  gap: 30px;
  align-items: center;
  padding-bottom: 30px;
  border-bottom: 1px solid #ececec;
  margin-bottom: 30px;
}

.bbs-account-left {
  display: flex;
  justify-content: center;
  align-items: center;
}

.bbs-account-middle {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.bbs-account-name {
  font-size: 22px;
  font-weight: 600;
  color: #222;
}

.bbs-account-email,
.bbs-account-dept {
  font-size: 14px;
  color: #666;
}

.bbs-account-right {
  display: flex;
  gap: 12px;
  align-items: baseline;
}

.bbs-settings-wrapper {
  max-width: 100%;
  margin: 0;
}

.bbs-settings-section {
  border-bottom: 1px solid #ececec;
  padding-bottom: 24px;
  margin-bottom: 24px;
}

.bbs-radio-group,
.bbs-checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.bbs-radio-group label,
.bbs-checkbox-group label {
  font-size: 14px;
  color: #444;
  cursor: pointer;
}

.bbs-file-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120px;
  height: 36px;
  padding: 0 16px;
  border: 1px solid #c00000;
  color: #c00000;
  background: #ffffff;
  font-size: 13px;
  cursor: pointer;
  border-radius: 2px;
}

.bbs-file-label:hover {
  background: #c00000;
  color: #ffffff;
}
